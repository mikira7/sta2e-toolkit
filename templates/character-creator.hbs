              </label>
              <input type="text" data-field="humanAugmentCustomFlawTraitName" value="{{humanAugmentCustomFlawTraitName}}" placeholder="Custom flaw trait" />
              <textarea data-field="humanAugmentCustomFlawTraitDescription" rows="2" placeholder="Custom flaw trait description">{{humanAugmentCustomFlawTraitDescription}}</textarea>
              {{/if}}
            </div>
          </dd>
          {{/if}}
          <dt>Attribute Boosts</dt>
          <dd>
            {{#if primaryFreeAttributeSelection}}
            {{#unless selectedFreeAttributeCount}}Choose any three attributes{{/unless}}
            {{/if}}
            {{#if hasSpeciesAttributeChoice}}
            {{#unless selectedSpeciesAttributeChoice}}Choose one species attribute{{/unless}}
            {{/if}}
            {{#each supportingAttributeRows as |attr|}}
            {{#if attr.boosted}}<span class="sta2e-cc-chip">{{attr.label}} +1</span>{{/if}}
            {{/each}}
          </dd>
        </dl>
      </article>

      <article class="sta2e-cc-panel">
        <h2>Species Talent Pool</h2>
        <ul class="sta2e-cc-choice-list sta2e-cc-species-talent-list">
          {{#each talentPool as |talent|}}
          <li class="{{#unless talent.available}}is-disabled{{/unless}}" data-description-root>
            <strong>{{talent.name}}</strong>
            {{#if talent.typeLabel}}<span>{{talent.typeLabel}}</span>{{/if}}
            {{#if talent.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{talent.description}}}</div>
            {{/if}}
          </li>
          {{/each}}
          {{#unless talentPool.length}}<li class="is-empty">No species talents assigned to the selected species.</li>{{/unless}}
        </ul>
      </article>
    </section>

    <section class="sta2e-cc-species-select-layout">
      <article class="sta2e-cc-panel sta2e-cc-species-list-panel">
        <div class="sta2e-cc-title-row">
          <h2>Species</h2>
          <label class="sta2e-cc-toggle">
            <input type="checkbox" data-field="mixedSpecies" {{checked mixedSpecies}} {{#if mixedSpeciesForced}}disabled{{/if}} />
            <span>Mixed Species</span>
          </label>
        </div>
        <label class="sta2e-cc-field sta2e-cc-species-search">
          <span>Search Species</span>
          <input type="search" data-species-filter value="{{speciesSearch}}" placeholder="Filter species" />
        </label>
        <ul class="sta2e-cc-choice-list sta2e-cc-species-card-list">
          {{#each speciesOptions as |species|}}
          <li data-species-card data-species-name="{{species.name}}" class="{{#if species.primarySelected}}is-primary{{/if}} {{#if species.secondarySelected}}is-secondary{{/if}}">
            <div class="sta2e-cc-species-card-head">
              <div class="sta2e-cc-species-card-title">
                {{#if species.tokenImage}}<img src="{{species.tokenImage}}" alt="{{species.name}} token image" />{{/if}}
                <strong>{{species.name}}</strong>
              </div>
              <div class="sta2e-cc-card-chip-row">
                {{#if species.primarySelected}}<span class="sta2e-cc-chip">Primary</span>{{/if}}
                {{#if species.secondarySelected}}<span class="sta2e-cc-chip">Secondary</span>{{/if}}
              </div>
            </div>
            <div class="sta2e-cc-card-chip-row">
              {{#if species.freeAttributeSelection}}
              <span class="sta2e-cc-chip">Any 3 Attributes</span>
              {{else}}
              {{#each species.attributeLabels as |attr|}}<span class="sta2e-cc-chip">{{attr.label}} +1</span>{{/each}}
              {{#if species.attributeChoiceLabel}}<span class="sta2e-cc-chip">{{species.attributeChoiceLabel}} +1</span>{{/if}}
              {{/if}}
              {{#if species.extraFocusCount}}<span class="sta2e-cc-chip">{{species.extraFocusCount}} Extra Focuses</span>{{/if}}
            </div>
            <div class="sta2e-cc-species-card-actions">
              <label class="sta2e-cc-talent-radio">
                <input type="radio" name="primarySpecies" data-field="primarySpecies" value="{{species.id}}" {{#if species.primarySelected}}checked{{/if}} />
                <span>Primary</span>
              </label>
              {{#if species.showSecondaryPicker}}
              <label class="sta2e-cc-talent-radio {{#if species.disabledAsSecondary}}is-disabled{{/if}}">
                <input type="radio" name="secondarySpecies" data-field="secondarySpecies" value="{{species.id}}" {{#if species.secondarySelected}}checked{{/if}} {{#if species.disabledAsSecondary}}disabled{{/if}} />
                <span>Secondary</span>
              </label>
              {{/if}}
            </div>
          </li>
          {{/each}}
          <li class="is-empty" data-species-filter-empty hidden>No species match this search.</li>
        </ul>
      </article>

      <article class="sta2e-cc-panel sta2e-cc-species-detail-panel">
        <h2>Selected Species</h2>
        <div class="sta2e-cc-species-detail-stack">
          <section class="sta2e-cc-species-detail-card">
            <span>Primary Species</span>
            {{#if primary.tokenImage}}<img class="sta2e-cc-species-detail-token" src="{{primary.tokenImage}}" alt="{{primary.name}} token image" />{{/if}}
            <h3>{{primary.name}}</h3>
            {{#if primary.description}}<div class="sta2e-cc-text-panel">{{{primary.description}}}</div>{{/if}}
          </section>
          {{#if mixedSpecies}}
          <section class="sta2e-cc-species-detail-card">
            <span>Secondary Species</span>
            {{#if secondary}}{{#if secondary.tokenImage}}<img class="sta2e-cc-species-detail-token" src="{{secondary.tokenImage}}" alt="{{secondary.name}} token image" />{{/if}}<h3>{{secondary.name}}</h3>{{else}}<h3>Choose secondary species</h3>{{/if}}
          </section>
          {{/if}}
        </div>
        {{#if primaryFreeAttributeSelection}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Attribute Boosts</h2>
          <div class="sta2e-cc-check-grid">
            {{#each freeAttributeChoices as |attr|}}
            <label>
              <input type="checkbox" data-field="freeAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
              {{attr.label}}
            </label>
            {{/each}}
          </div>
        </div>
        {{/if}}
        {{#if hasSpeciesAttributeChoice}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Attribute Choice</h2>
          <div class="sta2e-cc-check-grid">
            {{#each speciesAttributeChoiceOptions as |attr|}}
            <label>
              <input type="radio" name="speciesAttributeChoice" data-field="speciesAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
              {{attr.label}} +1
            </label>
            {{/each}}
          </div>
        </div>
        {{/if}}
        {{#if speciesExtraFocusCount}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Bonus Focuses</h2>
          <p>The primary species ability grants extra focuses.</p>
          {{#each speciesFocusSelections as |slot|}}
          <div class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Species Focus {{slot.number}}</span>
            <div class="sta2e-cc-inline-actions">
              <select data-field="speciesFocus" data-index="{{slot.index}}">
                <option value="">Choose configured focus</option>
                {{#each slot.options as |focus|}}
                <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
                {{/each}}
              </select>
              <button type="button" data-action="randomSpeciesFocus" data-index="{{slot.index}}" title="Roll random species focus">
                <i class="fas fa-dice"></i>
              </button>
            </div>
            <input type="text" data-field="speciesCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
          </div>
          {{/each}}
        </div>
        {{/if}}
      </article>
    </section>
    {{/if}}

    {{#if stepTwoActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Character Department</h2>
        <label class="sta2e-cc-field">
          <span>Department</span>
          <select data-field="supportingDepartment">
            <option value="">Choose department</option>
            {{#each supportingDepartmentOptions as |department|}}
            <option value="{{department.key}}" {{#if department.selected}}selected{{/if}}>{{department.label}}</option>
            {{/each}}
          </select>
        </label>
      </article>

      <article class="sta2e-cc-panel">
        <h2>Extra Trait</h2>
        <label class="sta2e-cc-field">
          <span>Configured Trait</span>
          <select data-field="supportingTrait">
            <option value="">Choose trait</option>
            {{#each supportingTraitOptions as |trait|}}
            <option value="{{trait.uuid}}" {{#if trait.selected}}selected{{/if}}>{{trait.name}}</option>
            {{/each}}
          </select>
        </label>
        <input type="text" data-field="supportingCustomTraitName" value="{{supportingCustomTraitName}}" placeholder="Custom trait" />
        <textarea data-field="supportingCustomTraitDescription" rows="2" placeholder="Custom trait description">{{supportingCustomTraitDescription}}</textarea>
      </article>
    </section>

    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Attributes</h2>
        <div class="sta2e-cc-score-assign-list">
          {{#each supportingAttributeRows as |row|}}
          <div class="sta2e-cc-score-drop-row {{#if row.boosted}}is-boosted{{/if}}" data-supporting-score-drop data-score-kind="attribute" data-score-key="{{row.key}}">
            <span>{{row.label}}</span>
            <button type="button" class="sta2e-cc-score-chip" draggable="true" data-supporting-score-chip data-score-kind="attribute" data-score-key="{{row.key}}" data-score-value="{{row.baseValue}}" title="Drag to swap values">
              {{row.baseValue}}
            </button>
            <strong>{{row.value}}</strong>
          </div>
          {{/each}}
        </div>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Departments</h2>
        <div class="sta2e-cc-score-assign-list">
          {{#each supportingDepartmentRows as |row|}}
          <div class="sta2e-cc-score-drop-row" data-supporting-score-drop data-score-kind="department" data-score-key="{{row.key}}">
            <span>{{row.label}}</span>
            <button type="button" class="sta2e-cc-score-chip" draggable="true" data-supporting-score-chip data-score-kind="department" data-score-key="{{row.key}}" data-score-value="{{row.value}}" title="Drag to swap values">
              {{row.value}}
            </button>
            <strong>{{row.value}}</strong>
          </div>
          {{/each}}
        </div>
      </article>
    </section>

    <section class="sta2e-cc-panel">
      <h2>Department Focuses</h2>
      <p>{{#if supportingDepartment}}Focuses filtered to {{supportingDepartmentLabel}}.{{else}}Choose a department to see configured focuses.{{/if}}</p>
      {{#each supportingFocusSelections as |slot|}}
      <div class="sta2e-cc-field sta2e-cc-field--wide">
        <span>Focus {{slot.number}}</span>
        <div class="sta2e-cc-inline-actions">
          <select data-field="supportingFocus" data-index="{{slot.index}}">
            <option value="">Choose focus</option>
            {{#each slot.options as |focus|}}
            <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
            {{/each}}
          </select>
          <button type="button" data-action="randomSupportingFocus" data-index="{{slot.index}}" title="Roll random focus">
            <i class="fas fa-dice"></i>
          </button>
        </div>
        <input type="text" data-field="supportingCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
      </div>
      {{/each}}
    </section>

    {{#if isSupervisoryCharacter}}
    <section class="sta2e-cc-panel">
      <h2>Value</h2>
      <label class="sta2e-cc-field">
        <span>Configured Value</span>
        <div class="sta2e-cc-inline-actions">
          <select data-field="supportingValue">
            <option value="">Choose value</option>
            {{#each supportingValueOptions as |value|}}
            <option value="{{value.uuid}}" {{#if value.selected}}selected{{/if}}>{{value.name}}</option>
            {{/each}}
          </select>
          <button type="button" data-action="randomSupportingValue" title="Roll random value">
            <i class="fas fa-dice"></i>
          </button>
        </div>
      </label>
      <input type="text" data-field="supportingCustomValueName" value="{{supportingCustomValueName}}" placeholder="Custom value" />
      <textarea data-field="supportingCustomValueDescription" rows="2" placeholder="Custom value description">{{supportingCustomValueDescription}}</textarea>
    </section>
    {{/if}}
    {{/if}}

    {{#if stepThreeActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Service Details</h2>
        <div class="sta2e-cc-final-details-grid">
          <label class="sta2e-cc-field">
            <span>Rank</span>
            <select data-field="rankSelect">
              <option value="">Choose configured rank</option>
              {{#each rankOptions as |rank|}}
              <option value="{{rank.id}}" {{#if rank.selected}}selected{{/if}}>{{rank.name}}</option>
              {{/each}}
            </select>
          </label>
          <label class="sta2e-cc-field">
            <span>Custom Rank</span>
            <input type="text" data-field="rank" value="{{customRank}}" placeholder="Custom rank" />
          </label>
          <label class="sta2e-cc-field">
            <span>Assignment</span>
            <input type="text" data-field="assignment" value="{{assignment}}" placeholder="Security Officer" />
          </label>
          {{#if canSelectPastime}}
          <label class="sta2e-cc-field">
            <span>Pastime</span>
            <input type="text" data-field="pastime" value="{{pastime}}" placeholder="Pastime" />
          </label>
          {{else}}
          <div class="sta2e-cc-text-panel">
            <h2>Pastime</h2>
            <p>Holograms do not select a pastime without Expanded Programming.</p>
          </div>
          {{/if}}
          <label class="sta2e-cc-field">
            <span>Pronouns</span>
            <input type="text" data-field="pronouns" value="{{pronouns}}" placeholder="Pronouns" />
          </label>
        </div>
        {{#if hasExpandedProgrammingTalent}}
        <div class="sta2e-cc-free-attrs">
          <h2>Expanded Programming Focuses</h2>
          <p>Select up to two additional focuses.</p>
          {{#each expandedProgrammingFocusSelections as |slot|}}
          <div class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Expanded Focus {{slot.number}}</span>
            <select data-field="expandedProgrammingFocus" data-index="{{slot.index}}">
              <option value="">Choose configured focus</option>
              {{#each slot.options as |focus|}}
              <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
              {{/each}}
            </select>
            <input type="text" data-field="expandedProgrammingCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
          </div>
          {{/each}}
        </div>
        {{/if}}
      </article>

      <article class="sta2e-cc-panel">
        <h2>Loadouts</h2>
        <details class="sta2e-cc-choice-collapse" open>
          <summary>Department{{#if supportingDepartmentLabel}}: {{supportingDepartmentLabel}}{{/if}}</summary>
          <ul class="sta2e-cc-choice-list">
            {{#each departmentEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
            {{#unless departmentEquipment.length}}<li class="is-empty">No equipment configured for this department.</li>{{/unless}}
          </ul>
        </details>
        <details class="sta2e-cc-choice-collapse" open>
          <summary>Assignment{{#if assignment}}: {{assignment}}{{/if}}</summary>
          <ul class="sta2e-cc-choice-list">
            {{#each assignmentEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
            {{#unless assignmentEquipment.length}}<li class="is-empty">No matching assignment loadout configured.</li>{{/unless}}
          </ul>
        </details>
      </article>
    </section>
    {{/if}}

    {{#if stepFourActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Scores</h2>
        <p>Attributes {{supportingAttributeTotal}}. Departments {{supportingDepartmentTotal}}.</p>
        <div class="sta2e-cc-score-grid">
          {{#each supportingAttributeRows as |row|}}<div><span>{{row.label}}</span><strong>{{row.value}}</strong></div>{{/each}}
          {{#each supportingDepartmentRows as |row|}}<div><span>{{row.label}}</span><strong>{{row.value}}</strong></div>{{/each}}
        </div>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Details</h2>
        <dl class="sta2e-cc-summary">
          <dt>Name</dt><dd>{{characterName}}</dd>
          <dt>Type</dt><dd>{{characterTypeDefinition.name}}</dd>
          <dt>Department</dt><dd>{{supportingDepartmentLabel}}</dd>
          <dt>Rank</dt><dd>{{rank}}</dd>
          <dt>Assignment</dt><dd>{{assignment}}</dd>
          <dt>Pastime</dt><dd>{{pastime}}</dd>
          <dt>Pronouns</dt><dd>{{pronouns}}</dd>
        </dl>
      </article>
    </section>
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Traits, Values, and Focuses</h2>
        <ul class="sta2e-cc-choice-list">
          {{#each traitList as |trait|}}<li><strong>{{trait.name}}</strong></li>{{/each}}
          {{#if selectedHumanAugmentFlawTrait}}<li><strong>{{selectedHumanAugmentFlawTrait.name}}</strong></li>{{/if}}
          {{#if selectedSupportingTrait}}<li><strong>{{selectedSupportingTrait.name}}</strong></li>{{/if}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each supportingValueSummary as |value|}}<li><strong>{{value.name}}</strong></li>{{/each}}
          {{#unless supportingValueSummary.length}}<li class="is-empty">No value selected.</li>{{/unless}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each supportingFocusSummary as |focus|}}<li><strong>{{focus.name}}</strong></li>{{/each}}
        </ul>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Talents and Equipment</h2>
        {{#if requiresHumanAugmentTalents}}
        <ul class="sta2e-cc-choice-list">
          {{#each selectedHumanAugmentTalents as |talent|}}<li><strong>{{talent.name}}</strong></li>{{/each}}
          {{#unless selectedHumanAugmentTalents.length}}<li class="is-empty">No extra talents selected.</li>{{/unless}}
        </ul>
        {{/if}}
        <ul class="sta2e-cc-choice-list">
          {{#each departmentEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
          {{#each assignmentEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
          {{#unless departmentEquipment.length}}{{#unless assignmentEquipment.length}}<li class="is-empty">No configured equipment.</li>{{/unless}}{{/unless}}
        </ul>
      </article>
    </section>
    {{/if}}

    <footer class="sta2e-cc-footer">
      <button type="button" data-action="previousStep">Back</button>
      {{#if stepOneActive}}<button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Scores</button>{{/if}}
      {{#if stepTwoActive}}<button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Details</button>{{/if}}
      {{#if stepThreeActive}}<button type="button" class="sta2e-cc-primary" data-action="nextStep">Review</button>{{/if}}
      {{#if stepFourActive}}
      <button type="button" class="sta2e-cc-primary" data-action="finalizeCharacter">
        <i class="fas fa-user-plus"></i> Finalize Character
      </button>
      {{/if}}
    </footer>
    {{else}}
    <section class="sta2e-cc-empty">
      <p>No species are configured yet.</p>
      <button type="button" data-action="openConfig">
        <i class="fas fa-gear"></i> Open Creator Data
      </button>
    </section>
    {{/if}}
    {{/if}}
  </main>
</div>
