            <i class="fas fa-pen"></i>
          </button>
          {{/if}}
          {{#if slot.editing}}
          <button type="button" class="sta2e-cc-icon-btn" data-action="cancelEditNpcFocus" data-index="{{slot.index}}" title="Revert to original">
            <i class="fas fa-undo"></i>
          </button>
          {{/if}}
          {{#if slot.removable}}
          <button type="button" class="sta2e-cc-icon-btn" data-action="removeNpcFocus" data-index="{{slot.index}}" title="Remove this slot">
            <i class="fas fa-times"></i>
          </button>
          {{/if}}
        </div>
        {{#if slot.showCustomFields}}
        <input type="text" data-field="npcCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus name" />
        <prose-mirror data-field="npcCustomFocusDescription" data-index="{{slot.index}}" name="npcCustomFocusDescription_{{slot.index}}" value="{{slot.customDescription}}"></prose-mirror>
        {{else}}
        {{#if slot.selected.description}}
        <div class="sta2e-cc-description-panel">{{{slot.selected.description}}}</div>
        {{/if}}
        {{/if}}
      </div>
      {{/each}}
      {{#if npcCanAddFocus}}
      <div class="sta2e-cc-field sta2e-cc-field--wide">
        <button type="button" data-action="addNpcFocus">+ Add Focus</button>
      </div>
      {{/if}}
    </section>
    {{/if}}

    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Special Rules</h2>
        <p>{{npcTalentCount}} / {{npcTalentLimit}} selected.</p>
        {{#each npcTalentSelections as |slot|}}
        <div class="sta2e-cc-field sta2e-cc-field--wide">
          <span>Special Rule {{slot.number}}</span>
          <div class="sta2e-cc-inline-actions">
            <select data-field="npcTalent" data-index="{{slot.index}}">
              <option value="">Choose configured talent</option>
              {{#each slot.options as |talent|}}
              <option value="{{talent.uuid}}" {{#if talent.selected}}selected{{/if}} {{#if talent.disabled}}disabled{{/if}}>{{talent.name}}</option>
              {{/each}}
            </select>
            <button type="button" class="sta2e-cc-icon-btn" data-action="randomNpcTalent" data-index="{{slot.index}}" title="Roll random special rule">
              <i class="fas fa-dice"></i>
            </button>
            {{#if slot.canEdit}}
            <button type="button" class="sta2e-cc-icon-btn" data-action="editNpcTalent" data-index="{{slot.index}}" title="Edit name and description">
              <i class="fas fa-pen"></i>
            </button>
            {{/if}}
            {{#if slot.editing}}
            <button type="button" class="sta2e-cc-icon-btn" data-action="cancelEditNpcTalent" data-index="{{slot.index}}" title="Revert to original">
              <i class="fas fa-undo"></i>
            </button>
            {{/if}}
            {{#if slot.removable}}
            <button type="button" class="sta2e-cc-icon-btn" data-action="removeNpcTalent" data-index="{{slot.index}}" title="Remove this slot">
              <i class="fas fa-times"></i>
            </button>
            {{/if}}
          </div>
          {{#if slot.showCustomFields}}
          <input type="text" data-field="npcCustomTalentName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom special rule name" />
          <prose-mirror data-field="npcCustomTalentDescription" data-index="{{slot.index}}" name="npcCustomTalentDescription_{{slot.index}}" value="{{slot.customDescription}}"></prose-mirror>
          {{else}}
          {{#if slot.selected.description}}
          <div class="sta2e-cc-description-panel">{{{slot.selected.description}}}</div>
          {{/if}}
          {{/if}}
        </div>
        {{/each}}
        {{#if npcCanAddTalent}}
        <div class="sta2e-cc-field sta2e-cc-field--wide">
          <button type="button" data-action="addNpcTalent">+ Add Special Rule</button>
        </div>
        {{/if}}
      </article>
      <article class="sta2e-cc-panel">
        <h2>Equipment</h2>
        <ul class="sta2e-cc-choice-list">
          {{#each npcEquipmentOptions as |item|}}
          <li>
            <label class="sta2e-cc-talent-radio">
              <input type="checkbox" data-field="npcEquipment" value="{{item.uuid}}" {{checked item.selected}} />
              <strong>{{item.name}}</strong>
            </label>
          </li>
          {{/each}}
          {{#unless npcEquipmentOptions.length}}<li class="is-empty">No equipment configured.</li>{{/unless}}
        </ul>
        <label class="sta2e-cc-field sta2e-cc-field--wide">
          <span>Notes</span>
          <textarea data-field="npcNotes" rows="5" placeholder="NPC notes">{{npcNotes}}</textarea>
        </label>
      </article>
    </section>
    {{/if}}

    {{#if stepFourActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Scores</h2>
        <p>Personal Threat {{npcPersonalThreat}}. Attributes {{npcAttributeTotal}}. Departments {{npcDepartmentTotal}}.</p>
        <div class="sta2e-cc-score-grid">
          {{#each npcAttributeRows as |row|}}<div><span>{{row.label}}</span><strong>{{row.value}}</strong></div>{{/each}}
          {{#each npcDepartmentRows as |row|}}<div><span>{{row.label}}</span><strong>{{row.value}}</strong></div>{{/each}}
        </div>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Details</h2>
        <dl class="sta2e-cc-summary">
          <dt>Name</dt><dd>{{characterName}}</dd>
          <dt>Type</dt><dd>{{npcTypeLabel}}</dd>
          <dt>Rank</dt><dd>{{rank}}</dd>
          <dt>Assignment</dt><dd>{{assignment}}</dd>
          <dt>Pronouns</dt><dd>{{pronouns}}</dd>
        </dl>
      </article>
    </section>
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Traits, Values, and Focuses</h2>
        <ul class="sta2e-cc-choice-list">
          {{#each traitList as |trait|}}<li><strong>{{trait.name}}</strong></li>{{/each}}
          {{#if selectedNpcRoleTrait}}<li><strong>{{selectedNpcRoleTrait.name}}</strong></li>{{/if}}
          {{#if selectedNpcExtraTrait}}<li><strong>{{selectedNpcExtraTrait.name}}</strong></li>{{/if}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each npcValueSummary as |value|}}<li><strong>{{value.name}}</strong></li>{{/each}}
          {{#unless npcValueSummary.length}}<li class="is-empty">No values selected.</li>{{/unless}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each npcFocusSummary as |focus|}}<li><strong>{{focus.name}}</strong></li>{{/each}}
          {{#unless npcFocusSummary.length}}<li class="is-empty">No focuses selected.</li>{{/unless}}
        </ul>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Special Rules and Equipment</h2>
        <ul class="sta2e-cc-choice-list">
          {{#each npcTalentSummary as |talent|}}<li><strong>{{talent.name}}</strong></li>{{/each}}
          {{#unless npcTalentSummary.length}}<li class="is-empty">No special rules selected.</li>{{/unless}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each selectedNpcEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
          {{#unless selectedNpcEquipment.length}}<li class="is-empty">No configured equipment selected.</li>{{/unless}}
        </ul>
      </article>
    </section>
    {{/if}}

    <footer class="sta2e-cc-footer">
      <button type="button" data-action="previousStep">Back</button>
      {{#if stepOneActive}}<button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Scores</button>{{/if}}
      {{#if stepTwoActive}}<button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Details</button>{{/if}}
      {{#if stepThreeActive}}<button type="button" class="sta2e-cc-primary" data-action="nextStep">Review</button>{{/if}}
      {{#if stepFourActive}}
      <button type="button" class="sta2e-cc-primary" data-action="finalizeCharacter">
        <i class="fas fa-user-plus"></i> Finalize NPC
      </button>
      {{/if}}
    </footer>
    {{else}}
    <section class="sta2e-cc-empty">
      <p>No species are configured yet.</p>
      <button type="button" data-action="openConfig">
        <i class="fas fa-gear"></i> Open Creator Data
      </button>
    </section>
    {{/if}}
    {{/if}}

    {{#if isSupportingCharacter}}
    {{#if hasSpecies}}
    <section class="sta2e-cc-panel">
      <h2>Preview Scores</h2>
      <div class="sta2e-cc-score-grid">
        {{#each supportingAttributeRows as |attr|}}
        <div class="{{#if attr.boosted}}is-boosted{{/if}}">
          <span>{{attr.label}}</span>
          <strong>{{attr.value}}</strong>
        </div>
        {{/each}}
        {{#each supportingDepartmentRows as |disc|}}
        <div>
          <span>{{disc.label}}</span>
          <strong>{{disc.value}}</strong>
        </div>
        {{/each}}
      </div>
    </section>

    {{#if stepOneActive}}
