    <section class="sta2e-cc-panel">
      <div class="sta2e-cc-field">
        <span>Experience</span>
        <div class="sta2e-cc-check-grid sta2e-cc-radio-grid">
          {{#each experienceOptions as |option|}}
          <label>
            <input type="radio" name="experience" data-field="experience" value="{{option.key}}" {{#if option.selected}}checked{{/if}} />
            {{option.name}}
          </label>
          {{/each}}
        </div>
