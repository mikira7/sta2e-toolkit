        {{#if slot.showCustomFields}}
        <input type="text" data-field="npcCustomValueName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom value name" />
        <prose-mirror data-field="npcCustomValueDescription" data-index="{{slot.index}}" name="npcCustomValueDescription_{{slot.index}}" value="{{slot.customDescription}}"></prose-mirror>
        {{else}}
        {{#if slot.selected.description}}
        <div class="sta2e-cc-description-panel">{{{slot.selected.description}}}</div>
        {{/if}}
        {{/if}}
      </div>
      {{/each}}
      {{#if npcCanAddValue}}
      <div class="sta2e-cc-field sta2e-cc-field--wide">
        <button type="button" data-action="addNpcValue">+ Add Value</button>
      </div>
      {{/if}}
    </section>
    {{/if}}

    {{#if npcFocusLimit}}
    <section class="sta2e-cc-panel">
      <h2>Focuses</h2>
      <p>{{npcFocusCount}} / {{npcFocusLimit}} selected.</p>
      {{#each npcFocusSelections as |slot|}}
      <div class="sta2e-cc-field sta2e-cc-field--wide">
        <span>Focus {{slot.number}}</span>
        <div class="sta2e-cc-inline-actions">
          <select data-field="npcFocus" data-index="{{slot.index}}">
            <option value="">Choose focus</option>
