      {{/each}}
    </nav>

    {{#each careerEventSelections as |slot|}}
    <div data-cc-creator-panel-group="careerEvents" data-cc-creator-panel="{{slot.tabId}}">
      <section class="sta2e-cc-career-event-layout">
        <article class="sta2e-cc-panel sta2e-cc-career-event-list-panel">
          <div class="sta2e-cc-title-row">
            <h2>Career Events</h2>
            <button type="button" class="sta2e-cc-icon-btn" data-action="randomCareerEvent" data-index="{{slot.index}}" title="Roll random career event">
              <i class="fas fa-dice"></i>
            </button>
          </div>
          <ul class="sta2e-cc-choice-list sta2e-cc-event-name-list">
            {{#each slot.eventOptions as |option|}}
            <li class="{{#if option.selected}}is-selected{{/if}}">
              <label class="sta2e-cc-talent-radio">
                <input type="radio" name="careerEvent{{option.slotIndex}}" data-field="careerEvent" data-index="{{option.slotIndex}}" value="{{option.id}}" {{#if option.selected}}checked{{/if}} />
                <strong>{{option.name}}</strong>
              </label>
            </li>
            {{/each}}
          </ul>
        </article>

        <article class="sta2e-cc-panel sta2e-cc-career-event-detail-panel">
