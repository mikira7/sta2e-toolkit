                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{slot.selectedTrait.description}}}</div>
                {{/if}}
              </li>
            </ul>
            {{/if}}
          </div>
          {{/if}}
          {{else}}
          <p>Choose or roll a career event.</p>
          {{/if}}
        </article>
      </section>
    </div>
    {{/each}}
    {{else}}
    <section class="sta2e-cc-empty">
      <p>No career events are configured yet.</p>
      <button type="button" data-action="openConfig">
        <i class="fas fa-gear"></i> Open Creator Data
      </button>
    </section>
