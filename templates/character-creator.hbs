            <button type="button" data-npc-score-step data-kind="attribute" data-score-key="{{row.key}}" data-delta="-1" {{#unless row.canDecrease}}disabled{{/unless}} title="Decrease {{row.label}}">
              <i class="fas fa-minus"></i>
            </button>
            <input type="number" value="{{row.value}}" readonly />
            <button type="button" data-npc-score-step data-kind="attribute" data-score-key="{{row.key}}" data-delta="1" {{#unless row.canIncrease}}disabled{{/unless}} title="Increase {{row.label}}">
              <i class="fas fa-plus"></i>
            </button>
          </div>
