<div class="sta2e-cc">
  <aside class="sta2e-cc-steps">
    {{#if typeChoiceActive}}
    <div class="sta2e-cc-step is-active">
      <span>00</span>
      <strong>Character Type</strong>
    </div>
    {{/if}}
    {{#if isSupportingCharacter}}
    {{#each supportingStepLabels as |row|}}
    <div class="sta2e-cc-step {{#if row.active}}is-active{{/if}}">
      <span>{{row.number}}</span>
      <strong>{{row.label}}</strong>
    </div>
    {{/each}}
    {{/if}}
    {{#if isNpcCharacter}}
    {{#each npcStepLabels as |row|}}
    <div class="sta2e-cc-step {{#if row.active}}is-active{{/if}}">
      <span>{{row.number}}</span>
      <strong>{{row.label}}</strong>
    </div>
    {{/each}}
    {{/if}}
    {{#if isPlayerCharacter}}
    <div class="sta2e-cc-step {{#if stepOneActive}}is-active{{/if}}">
      <span>01</span>
      <strong>Species</strong>
    </div>
    <div class="sta2e-cc-step {{#if stepTwoActive}}is-active{{/if}}">
      <span>02</span>
      <strong>Environment</strong>
    </div>
    <div class="sta2e-cc-step {{#if stepThreeActive}}is-active{{/if}}">
      <span>03</span>
      <strong>Upbringing</strong>
    </div>
    <div class="sta2e-cc-step {{#if stepFourActive}}is-active{{/if}}">
      <span>04</span>
      <strong>Career Path</strong>
    </div>
    <div class="sta2e-cc-step {{#if stepFiveActive}}is-active{{/if}}">
      <span>05</span>
      <strong>Experience</strong>
    </div>
    <div class="sta2e-cc-step {{#if stepSixActive}}is-active{{/if}}">
      <span>06</span>
      <strong>Career Events</strong>
    </div>
    <div class="sta2e-cc-step {{#if stepSevenActive}}is-active{{/if}}">
      <span>07</span>
      <strong>Finishing Touches</strong>
    </div>
    <div class="sta2e-cc-step {{#if reviewActive}}is-active{{/if}}">
      <span>08</span>
      <strong>Review</strong>
    </div>
    {{/if}}
  </aside>

  <main class="sta2e-cc-main">
    <header class="sta2e-cc-title-row">
      <div>
        {{#if typeChoiceActive}}
        <h1>Character Type</h1>
        <p>Choose the kind of character to create.</p>
        {{/if}}
        {{#if isSupportingCharacter}}
        {{#if stepOneActive}}
        <h1>{{characterTypeDefinition.name}}: Species Selection</h1>
        <p>Choose species grants before assigning the short-form character details.</p>
        {{/if}}
        {{#if stepTwoActive}}
        <h1>{{characterTypeDefinition.name}}: Scores, Traits, and Focuses</h1>
        <p>Assign arrays, choose a department, add one extra trait, and choose department focuses.</p>
        {{/if}}
        {{#if stepThreeActive}}
        <h1>{{characterTypeDefinition.name}}: Service Details</h1>
        <p>Enter name, rank, assignment, pastime, and pronouns.</p>
        {{/if}}
        {{#if stepFourActive}}
        <h1>{{characterTypeDefinition.name}} Review</h1>
        <p>Review the character before finalizing.</p>
        {{/if}}
        {{/if}}
        {{#if isNpcCharacter}}
        {{#if stepOneActive}}
        <h1>{{npcTypeLabel}}: Species Selection</h1>
        <p>Choose species traits and any species-granted options for this NPC.</p>
        {{/if}}
        {{#if stepTwoActive}}
        <h1>{{npcTypeLabel}}: Scores</h1>
        <p>Assign the NPC score array and apply species attribute modifiers.</p>
        {{/if}}
        {{#if stepThreeActive}}
        <h1>{{npcTypeLabel}}: Details</h1>
        <p>Add role traits, values, focuses, special rules, equipment, and notes.</p>
        {{/if}}
        {{#if stepFourActive}}
        <h1>{{npcTypeLabel}} Review</h1>
        <p>Review the NPC before finalizing.</p>
        {{/if}}
        {{/if}}
        {{#if isPlayerCharacter}}
        {{#if stepOneActive}}
        <h1>Step One: Species Selection</h1>
        <p>Choose a primary species. Mixed species use the primary species ability and attribute boosts, then add the secondary species talent list.</p>
        {{/if}}
        {{#if stepTwoActive}}
        {{#if isJemHadarLifepath}}
        <h1>Step Two: Hatchery</h1>
        <p>Choose the character's hatchery, value, attribute increase, and department increase.</p>
        {{else}}
        {{#if isVortaLifepath}}
        <h1>Step Two: Vorta Cloning</h1>
        <p>Choose the character's engineered value, attribute increases, and department increases.</p>
        {{else}}
        <h1>Step Two: Environment</h1>
        <p>Choose the character's formative environment, value, attribute increase, and department increase.</p>
        {{/if}}
        {{/if}}
        {{/if}}
        {{#if stepThreeActive}}
        {{#if isJemHadarLifepath}}
        <h1>Step Three: Hatchery Training</h1>
        <p>Choose the hatchery focus and talent.</p>
        {{else}}
        {{#if isVortaLifepath}}
        <h1>Step Three: Vorta Conditioning</h1>
        <p>Choose the cloning focus and talent.</p>
        {{else}}
        <h1>Step Three: Upbringing</h1>
        <p>Choose or roll the character's upbringing, decide whether they accepted or rebelled, then select a department, focus, and talent.</p>
        {{/if}}
        {{/if}}
        {{/if}}
        {{#if stepFourActive}}
        <h1>Step Four: Career Path</h1>
        <p>Choose or roll the character's profession, then assign career attributes, value, focuses, and talent.</p>
        {{/if}}
        {{#if stepFiveActive}}
        <h1>Step Five: Experience</h1>
        <p>Choose career length, then add a value and talent.</p>
        {{/if}}
        {{#if stepSixActive}}
        <h1>Step Six: Career Events</h1>
        <p>Choose or roll two career events, then select a suggested focus or write a custom focus for each.</p>
        {{/if}}
        {{#if stepSevenActive}}
        <h1>Step Seven: Finishing Touches</h1>
        <p>Apply final score checks, choose a final value and talent, then add role and service details.</p>
        {{/if}}
        {{#if reviewActive}}
        <h1>Review</h1>
        <p>Review the character choices before finalizing.</p>
        {{/if}}
        {{/if}}
      </div>
      {{#unless typeChoiceActive}}
      <label class="sta2e-cc-field sta2e-cc-name-field">
        <span>Character Name</span>
        <div class="sta2e-cc-inline-actions">
          <input type="text" data-field="characterName" value="{{characterName}}" placeholder="Character name" />
          <select data-field="randomNameGender" title="Random first name list">
            <option value="any" {{#if (eq randomNameGender "any")}}selected{{/if}}>Any</option>
            <option value="male" {{#if (eq randomNameGender "male")}}selected{{/if}}>Male</option>
            <option value="female" {{#if (eq randomNameGender "female")}}selected{{/if}}>Female</option>
          </select>
          <button type="button" data-action="randomCharacterName" title="Roll random character name">
            <i class="fas fa-dice"></i>
          </button>
        </div>
      </label>
      {{/unless}}
      <button type="button" data-action="openConfig">
        <i class="fas fa-gear"></i> Creator Data
      </button>
    </header>

    {{#if typeChoiceActive}}
    <section class="sta2e-cc-grid sta2e-cc-three sta2e-cc-type-grid">
      {{#each characterTypeOptions as |option|}}
      <article class="sta2e-cc-panel sta2e-cc-type-card">
        <h2>{{option.name}}</h2>
        <p>{{option.description}}</p>
        <button type="button" class="sta2e-cc-primary" data-action="selectCharacterType" data-character-type="{{option.key}}">
          Select
        </button>
      </article>
      {{/each}}
    </section>
    {{/if}}

    {{#if isPlayerCharacter}}
    {{#if hasSpecies}}
    <section class="sta2e-cc-panel">
      <h2>Preview Scores</h2>
      <div class="sta2e-cc-score-grid">
        {{#each previewAttributes as |attr|}}
        <div class="{{#if attr.boosted}}is-boosted{{/if}}">
          <span>{{attr.label}}</span>
          <strong>{{attr.value}}</strong>
        </div>
        {{/each}}
        {{#each previewDisciplines as |disc|}}
        <div class="{{#if disc.boosted}}is-boosted{{/if}}">
          <span>{{disc.label}}</span>
          <strong>{{disc.value}}</strong>
        </div>
        {{/each}}
      </div>
    </section>

    {{#if stepOneActive}}
    <section class="sta2e-cc-grid sta2e-cc-two sta2e-cc-species-grants-grid">
      <article class="sta2e-cc-panel sta2e-cc-species-grants-panel">
        <h2>Species Grants</h2>
        <dl class="sta2e-cc-summary">
          <dt>Trait</dt>
          <dd>
            {{#each traitList as |trait|}}
            <span class="sta2e-cc-chip">{{trait.name}}</span>
            {{#if trait.description}}
            <div class="sta2e-cc-inline-detail" data-description-root>
              <button type="button" class="sta2e-cc-link-btn" data-toggle-description>{{trait.sourceName}} Trait Description</button>
              <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{trait.description}}}</div>
            </div>
            {{/if}}
            {{/each}}
            {{#unless traitList.length}}No trait assigned{{/unless}}
          </dd>

          <dt>Species Ability</dt>
          <dd data-description-root>
            {{#if primary.abilityName}}{{primary.abilityName}}{{else}}No ability assigned{{/if}}
            {{#if primary.abilityDescription}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Ability Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{primary.abilityDescription}}}</div>
            {{/if}}
          </dd>

          {{#if hasSpeciesEsotericOptions}}
          <dt>Esoteric Talents</dt>
          <dd>
            {{#each speciesEsotericSelections as |slot|}}
            <label class="sta2e-cc-field">
              <span>Species Esoteric Talent {{slot.number}}</span>
              <select data-field="speciesEsotericTalent" data-index="{{slot.index}}">
                <option value="">Choose Esoteric talent</option>
                {{#each slot.options as |talent|}}
                <option value="{{talent.uuid}}" {{#if talent.selected}}selected{{/if}} {{#if talent.disabled}}disabled{{/if}}>{{talent.name}}</option>
                {{/each}}
              </select>
            </label>
            {{#if slot.selected}}
            <div class="sta2e-cc-inline-detail" data-description-root>
              {{#if slot.selected.typeLabel}}<span>{{slot.selected.typeLabel}}</span>{{/if}}
              {{#if slot.selected.description}}
              <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Esoteric Talent Description</button>
              <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{slot.selected.description}}}</div>
              {{/if}}
            </div>
            {{/if}}
            {{/each}}
          </dd>
          {{/if}}

          {{#if requiresBorgImplants}}
          <dt>Borg Implants</dt>
          <dd>
            <div class="sta2e-cc-borg-implants">
              <div class="sta2e-cc-card-chip-row">
                <span class="sta2e-cc-chip">{{selectedBorgImplantCount}} / 3 selected</span>
              </div>
              <ul class="sta2e-cc-choice-list sta2e-cc-borg-implant-list">
                {{#each borgImplantOptions as |talent|}}
                <li class="{{#if talent.selected}}is-selected{{/if}} {{#unless talent.available}}is-disabled{{/unless}}" data-description-root>
                  <label class="sta2e-cc-borg-implant-choice">
                    <input type="checkbox" data-field="borgImplant" value="{{talent.uuid}}" {{checked talent.selected}} {{#unless talent.available}}disabled{{/unless}} />
                    <span>
                      <strong>{{talent.name}}</strong>
                      {{#if talent.typeLabel}}<em>{{talent.typeLabel}}</em>{{/if}}
                      {{#unless talent.available}}<em>Unavailable: {{talent.unavailableReason}}</em>{{/unless}}
                    </span>
                  </label>
                  {{#if talent.description}}
                  <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                  <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{talent.description}}}</div>
                  {{/if}}
                </li>
                {{/each}}
              </ul>
              {{#unless hasBorgImplantOptions}}No Borg implants configured yet.{{/unless}}
            </div>
          </dd>
          {{/if}}

          {{#if requiresHumanAugmentTalents}}
          <dt>Augment Talents</dt>
          <dd>
            <div class="sta2e-cc-start-talents">
              <div class="sta2e-cc-card-chip-row">
                <span class="sta2e-cc-chip">{{selectedHumanAugmentTalentCount}} / 2 selected</span>
              </div>
              <ul class="sta2e-cc-choice-list sta2e-cc-start-talent-list">
                {{#each humanAugmentTalentOptions as |talent|}}
                <li class="{{#if talent.selected}}is-selected{{/if}} {{#unless talent.available}}is-disabled{{/unless}}" data-description-root>
                  <label class="sta2e-cc-start-talent-choice">
                    <input type="checkbox" data-field="humanAugmentTalent" value="{{talent.uuid}}" {{checked talent.selected}} {{#unless talent.available}}disabled{{/unless}} />
                    <span>
                      <strong>{{talent.name}}</strong>
                      {{#if talent.typeLabel}}<em>{{talent.typeLabel}}</em>{{/if}}
                      {{#if talent.requirementLabel}}<em>{{talent.requirementLabel}}</em>{{/if}}
                      {{#unless talent.available}}<em>Unavailable: {{talent.unavailableReason}}</em>{{/unless}}
                    </span>
                  </label>
                  {{#if talent.description}}
                  <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                  <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{talent.description}}}</div>
                  {{/if}}
                </li>
                {{/each}}
              </ul>
              {{#unless hasHumanAugmentTalentOptions}}No Augment talents configured yet.{{/unless}}
              {{#if humanAugmentRequiresFlawTrait}}
              <label class="sta2e-cc-field sta2e-cc-field--wide">
                <span>Additional Flaw Trait</span>
                <select data-field="humanAugmentFlawTrait">
                  <option value="">Choose configured trait</option>
                  {{#each humanAugmentFlawTraitOptions as |trait|}}
                  <option value="{{trait.uuid}}" {{#if trait.selected}}selected{{/if}}>{{trait.name}}</option>
                  {{/each}}
                </select>
              </label>
              <input type="text" data-field="humanAugmentCustomFlawTraitName" value="{{humanAugmentCustomFlawTraitName}}" placeholder="Custom flaw trait" />
              <textarea data-field="humanAugmentCustomFlawTraitDescription" rows="2" placeholder="Custom flaw trait description">{{humanAugmentCustomFlawTraitDescription}}</textarea>
              {{/if}}
            </div>
          </dd>
          {{/if}}

          <dt>Attribute Boosts</dt>
          <dd>
            {{#if primaryFreeAttributeSelection}}
            {{#unless selectedFreeAttributeCount}}Choose any three attributes{{/unless}}
            {{/if}}
            {{#if hasSpeciesAttributeChoice}}
            {{#unless selectedSpeciesAttributeChoice}}Choose one species attribute{{/unless}}
            {{/if}}
            {{#each previewAttributes as |attr|}}
            {{#if attr.boosted}}<span class="sta2e-cc-chip">{{attr.label}} +1</span>{{/if}}
            {{/each}}
          </dd>
        </dl>
      </article>

      <article class="sta2e-cc-panel sta2e-cc-species-talent-panel">
        <h2>Species Talent Pool</h2>
        <ul class="sta2e-cc-choice-list sta2e-cc-species-talent-list">
          {{#each talentPool as |talent|}}
          <li class="{{#unless talent.available}}is-disabled{{/unless}}" data-description-root>
            <strong>{{talent.name}}</strong>
            {{#if talent.typeLabel}}<span>{{talent.typeLabel}}</span>{{/if}}
            {{#if talent.requirementLabel}}<span>{{talent.requirementLabel}}</span>{{/if}}
            {{#unless talent.available}}<em>Unavailable: {{talent.unavailableReason}}</em>{{/unless}}
            {{#if talent.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{talent.description}}}</div>
            {{/if}}
          </li>
          {{/each}}
          {{#unless talentPool.length}}
          <li class="is-empty">No species talents assigned to the selected species.</li>
          {{/unless}}
        </ul>
      </article>
    </section>

    <section class="sta2e-cc-species-select-layout">
      <article class="sta2e-cc-panel sta2e-cc-species-list-panel">
        <div class="sta2e-cc-title-row">
          <h2>Species</h2>
          <label class="sta2e-cc-toggle">
            <input type="checkbox" data-field="mixedSpecies" {{checked mixedSpecies}} {{#if mixedSpeciesForced}}disabled{{/if}} />
            <span>Mixed Species</span>
          </label>
        </div>
        <label class="sta2e-cc-field sta2e-cc-species-search">
          <span>Search Species</span>
          <input type="search" data-species-filter value="{{speciesSearch}}" placeholder="Filter species" />
        </label>
        <ul class="sta2e-cc-choice-list sta2e-cc-species-card-list">
          {{#each speciesOptions as |species|}}
          <li data-species-card data-species-name="{{species.name}}" class="{{#if species.primarySelected}}is-primary{{/if}} {{#if species.secondarySelected}}is-secondary{{/if}}">
            <div class="sta2e-cc-species-card-head">
              <div class="sta2e-cc-species-card-title">
                {{#if species.tokenImage}}<img src="{{species.tokenImage}}" alt="{{species.name}} token image" />{{/if}}
                <strong>{{species.name}}</strong>
              </div>
              <div class="sta2e-cc-card-chip-row">
                {{#if species.primarySelected}}<span class="sta2e-cc-chip">Primary</span>{{/if}}
                {{#if species.secondarySelected}}<span class="sta2e-cc-chip">Secondary</span>{{/if}}
              </div>
            </div>
            {{#if species.description}}
            <div data-description-root>
              <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
              <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{species.description}}}</div>
            </div>
            {{/if}}
            <div class="sta2e-cc-card-chip-row">
              {{#if species.freeAttributeSelection}}
              <span class="sta2e-cc-chip">Any 3 Attributes</span>
              {{else}}
              {{#each species.attributeLabels as |attr|}}
              <span class="sta2e-cc-chip">{{attr.label}} +1</span>
              {{/each}}
              {{#if species.attributeChoiceLabel}}<span class="sta2e-cc-chip">{{species.attributeChoiceLabel}} +1</span>{{/if}}
              {{/if}}
              {{#if species.extraFocusCount}}<span class="sta2e-cc-chip">{{species.extraFocusCount}} Extra Focuses</span>{{/if}}
            </div>
            <div class="sta2e-cc-species-card-actions">
              <label class="sta2e-cc-talent-radio">
                <input type="radio" name="primarySpecies" data-field="primarySpecies" value="{{species.id}}" {{#if species.primarySelected}}checked{{/if}} />
                <span>Primary</span>
              </label>
              {{#if species.showSecondaryPicker}}
              <label class="sta2e-cc-talent-radio {{#if species.disabledAsSecondary}}is-disabled{{/if}}">
                <input type="radio" name="secondarySpecies" data-field="secondarySpecies" value="{{species.id}}" {{#if species.secondarySelected}}checked{{/if}} {{#if species.disabledAsSecondary}}disabled{{/if}} />
                <span>Secondary</span>
              </label>
              {{/if}}
            </div>
          </li>
          {{/each}}
          <li class="is-empty" data-species-filter-empty hidden>No species match this search.</li>
        </ul>
      </article>

      <article class="sta2e-cc-panel sta2e-cc-species-detail-panel">
        <h2>Selected Species</h2>
        <div class="sta2e-cc-species-detail-stack">
          <section class="sta2e-cc-species-detail-card">
            <span>Primary Species</span>
            {{#if primary.tokenImage}}<img class="sta2e-cc-species-detail-token" src="{{primary.tokenImage}}" alt="{{primary.name}} token image" />{{/if}}
            <h3>{{primary.name}}</h3>
            {{#if primary.description}}<div class="sta2e-cc-text-panel">{{{primary.description}}}</div>{{/if}}
          </section>
          {{#if mixedSpecies}}
          <section class="sta2e-cc-species-detail-card">
            <span>Secondary Species</span>
            {{#if secondary}}
            {{#if secondary.tokenImage}}<img class="sta2e-cc-species-detail-token" src="{{secondary.tokenImage}}" alt="{{secondary.name}} token image" />{{/if}}
            <h3>{{secondary.name}}</h3>
            {{#if secondary.description}}<div class="sta2e-cc-text-panel">{{{secondary.description}}}</div>{{/if}}
            {{else}}
            <h3>Choose secondary species</h3>
            <p>The secondary species adds its trait and contributes to the available species talent pool.</p>
            {{/if}}
          </section>
          {{/if}}
        </div>

        {{#if primaryFreeAttributeSelection}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Attribute Boosts</h2>
          <p>This species lets you choose any three attributes for +1.</p>
          <div class="sta2e-cc-check-grid">
            {{#each freeAttributeChoices as |attr|}}
            <label>
              <input type="checkbox" data-field="freeAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
              {{attr.label}}
            </label>
            {{/each}}
          </div>
        </div>
        {{/if}}
        {{#if hasSpeciesAttributeChoice}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Attribute Choice</h2>
          <div class="sta2e-cc-check-grid">
            {{#each speciesAttributeChoiceOptions as |attr|}}
            <label>
              <input type="radio" name="speciesAttributeChoice" data-field="speciesAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
              {{attr.label}} +1
            </label>
            {{/each}}
          </div>
        </div>
        {{/if}}
        {{#if speciesExtraFocusCount}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Bonus Focuses</h2>
          <p>The primary species ability grants extra focuses.</p>
          {{#each speciesFocusSelections as |slot|}}
          <div class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Species Focus {{slot.number}}</span>
            <div class="sta2e-cc-inline-actions">
              <select data-field="speciesFocus" data-index="{{slot.index}}">
                <option value="">Choose configured focus</option>
                {{#each slot.options as |focus|}}
                <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
                {{/each}}
              </select>
              <button type="button" data-action="randomSpeciesFocus" data-index="{{slot.index}}" title="Roll random species focus">
                <i class="fas fa-dice"></i>
              </button>
            </div>
            <input type="text" data-field="speciesCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
          </div>
          {{/each}}
        </div>
        {{/if}}
      </article>
    </section>
    {{/if}}

    {{#if stepTwoActive}}
    {{#if isJemHadarLifepath}}
    <section class="sta2e-cc-panel">
      <h2>Hatchery</h2>
      <div class="sta2e-cc-check-grid sta2e-cc-radio-grid">
        {{#each jemHadarHatcheryOptions as |hatchery|}}
        <label>
          <input type="radio" name="jemHadarHatchery" data-field="jemHadarHatchery" value="{{hatchery.key}}" {{#if hatchery.selected}}checked{{/if}} />
          {{hatchery.name}}
        </label>
        {{/each}}
      </div>
      {{#if selectedJemHadarHatchery.description}}
      <div class="sta2e-cc-text-panel">
        <h2>{{selectedJemHadarHatchery.name}}</h2>
        <p>{{selectedJemHadarHatchery.description}}</p>
      </div>
      {{/if}}
    </section>

    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Value</h2>
        {{#if selectedJemHadarHatchery.valuePrompt}}<p>{{selectedJemHadarHatchery.valuePrompt}}</p>{{/if}}
        <label class="sta2e-cc-field">
          <span>Configured Value</span>
          <div class="sta2e-cc-inline-actions">
            <select data-field="jemHadarHatcheryValue">
              <option value="">Choose value</option>
              {{#each jemHadarHatcheryValueOptions as |value|}}
              <option value="{{value.uuid}}" {{#if value.selected}}selected{{/if}}>{{value.name}}</option>
              {{/each}}
            </select>
            <button type="button" data-action="randomJemHadarHatcheryValue" title="Roll random value">
              <i class="fas fa-dice"></i>
            </button>
          </div>
        </label>
