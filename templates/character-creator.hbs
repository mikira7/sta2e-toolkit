              <option value="">Choose value</option>
              {{#each careerValueOptions as |value|}}
              <option value="{{value.uuid}}" {{#if value.selected}}selected{{/if}}>{{value.name}}</option>
              {{/each}}
            </select>
            <button type="button" data-action="randomCareerValue" title="Roll random value">
              <i class="fas fa-dice"></i>
            </button>
          </div>
        </label>
        <input type="text" data-field="careerCustomValueName" value="{{careerCustomValueName}}" placeholder="Custom value" />
        <textarea data-field="careerCustomValueDescription" rows="2" placeholder="Custom value description">{{careerCustomValueDescription}}</textarea>
        {{#if selectedCareerValue}}
        <ul class="sta2e-cc-choice-list">
          <li data-description-root>
            <strong>{{selectedCareerValue.name}}</strong>
            {{#if selectedCareerValue.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{selectedCareerValue.description}}}</div>
            {{/if}}
          </li>
        </ul>
        {{/if}}
      </article>

      <article class="sta2e-cc-panel">
        <h2>Attributes</h2>
        {{#if careerPath.attributeDescription}}<div class="sta2e-cc-text-panel">{{{careerPath.attributeDescription}}}</div>{{/if}}
        {{#if careerRequiredAttributes.length}}
        <p class="{{#if careerAttributeRequirementSatisfied}}sta2e-cc-rule-ok{{else}}sta2e-cc-rule-warning{{/if}}">At least one point must be spent in {{careerAttributeRequirementLabel}}.</p>
        {{/if}}
        <p>{{careerAttributeSpendRemaining}} point(s) remaining.</p>
        <div class="sta2e-cc-attribute-steppers">
          {{#each careerAttributeChoices as |attr|}}
          <div class="sta2e-cc-stepper">
            <span>{{attr.label}}{{#if attr.required}} *{{/if}}</span>
            <button type="button" data-career-attribute-step data-attribute="{{attr.key}}" data-delta="-1" {{#unless attr.canDecrease}}disabled{{/unless}} title="Decrease {{attr.label}}">
              <i class="fas fa-minus"></i>
            </button>
            <input type="number" data-field="careerAttributeSpend" data-attribute="{{attr.key}}" value="{{attr.value}}" min="0" max="2" readonly />
            <button type="button" data-career-attribute-step data-attribute="{{attr.key}}" data-delta="1" {{#unless attr.canIncrease}}disabled{{/unless}} title="Increase {{attr.label}}">
              <i class="fas fa-plus"></i>
            </button>
          </div>
          {{/each}}
        </div>
      </article>
    </section>

    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
