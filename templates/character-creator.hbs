      <label class="sta2e-cc-field sta2e-cc-talent-search">
        <span>Search Talents</span>
        <input type="search" data-talent-filter placeholder="Search talents" autocomplete="off" />
      </label>
      <ul class="sta2e-cc-choice-list" data-talent-filter-list>
        {{#each careerTalentChoices as |talent|}}
