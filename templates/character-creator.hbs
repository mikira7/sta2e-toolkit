        {{#if careerPath.departmentDescription}}<div class="sta2e-cc-text-panel">{{{careerPath.departmentDescription}}}</div>{{/if}}
        <div class="sta2e-cc-field sta2e-cc-field--wide">
          <span>Choose one department for +2</span>
          <div class="sta2e-cc-check-grid sta2e-cc-radio-grid">
            {{#each careerDepartmentPlusTwoChoices as |department|}}
            <label class="{{#if department.disabled}}is-disabled{{/if}}">
              <input type="radio" name="careerDepartmentPlusTwo" data-field="careerDepartmentPlusTwo" value="{{department.key}}" {{#if department.selected}}checked{{/if}} {{#if department.disabled}}disabled{{/if}} />
              {{department.label}} +2
            </label>
            {{/each}}
          </div>
        </div>
        <div class="sta2e-cc-field sta2e-cc-field--wide">
          <span>Choose two other departments for +1</span>
          <div class="sta2e-cc-check-grid">
            {{#each careerDepartmentPlusOneChoices as |department|}}
            <label class="{{#if department.disabled}}is-disabled{{/if}}">
              <input type="checkbox" data-field="careerDepartmentPlusOne" value="{{department.key}}" {{checked department.selected}} {{#if department.disabled}}disabled{{/if}} />
              {{department.label}} +1
            </label>
            {{/each}}
          </div>
          <p>{{careerDepartmentPlusOneRemaining}} +1 department pick(s) remaining.</p>
        </div>
        {{#if careerDepartmentReallocationAllowed}}
        <div class="sta2e-cc-grid">
          <label class="sta2e-cc-field">
            <span>Optional reduce -1</span>
            <select data-field="careerDepartmentReallocationFrom">
              <option value="">No reduction</option>
              {{#each careerDepartmentReallocationFromChoices as |department|}}
              <option value="{{department.key}}" {{#if department.selected}}selected{{/if}}>{{department.label}} ({{department.baseValue}})</option>
              {{/each}}
            </select>
          </label>
          <label class="sta2e-cc-field">
            <span>Optional add +1</span>
            <select data-field="careerDepartmentReallocationTo" {{#unless selectedCareerDepartmentReallocationFrom}}disabled{{/unless}}>
              <option value="">Choose department</option>
              {{#each careerDepartmentReallocationToChoices as |department|}}
              <option value="{{department.key}}" {{#if department.selected}}selected{{/if}}>{{department.label}} ({{department.baseValue}})</option>
              {{/each}}
            </select>
          </label>
        </div>
        {{/if}}
        <ul class="sta2e-cc-choice-list">
          {{#each careerDepartmentSummary as |department|}}
          <li><strong>{{department}}</strong></li>
          {{/each}}
          {{#unless careerDepartmentSummary.length}}
          <li class="is-empty">Choose the career department increases.</li>
          {{/unless}}
        </ul>
      </article>

      <article class="sta2e-cc-panel">
        <h2>Focuses</h2>
        {{#if careerPath.focusDescription}}<div class="sta2e-cc-text-panel">{{{careerPath.focusDescription}}}</div>{{/if}}
        {{#each careerFocusSelections as |slot|}}
        <div class="sta2e-cc-field sta2e-cc-field--wide">
          <span>Focus {{slot.number}}</span>
          <div class="sta2e-cc-inline-actions">
            <select data-field="careerFocus" data-index="{{slot.index}}">
              <option value="">Choose focus</option>
              {{#each slot.options as |focus|}}
              <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
              {{/each}}
            </select>
            <button type="button" data-action="randomCareerFocus" data-index="{{slot.index}}" title="Roll random focus">
              <i class="fas fa-dice"></i>
            </button>
          </div>
          <input type="text" data-field="careerCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
        </div>
        {{/each}}
      </article>
    </section>

    <section class="sta2e-cc-panel">
