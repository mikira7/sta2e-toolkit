      <button type="button" data-cc-creator-tab-group="finishing" data-cc-creator-tab="checks">Attribute & Department Check</button>
      <button type="button" data-cc-creator-tab-group="finishing" data-cc-creator-tab="value">Final Value & Talent</button>
      <button type="button" data-cc-creator-tab-group="finishing" data-cc-creator-tab="details">Final Details</button>
    </nav>

    <div data-cc-creator-panel-group="finishing" data-cc-creator-panel="checks">
      <section class="sta2e-cc-grid sta2e-cc-two">
        <article class="sta2e-cc-panel">
          <h2>Attribute Check</h2>
          <p>{{#if untappedPotential}}Untapped Potential: attributes cannot exceed 11.{{else}}Attributes cannot exceed 12, and only one may be 12.{{/if}}</p>
          <p>Total: {{finalAttributeTotal}} / 56</p>
          <p>Redistribution remaining: {{finalAttributeContext.redistributionRemaining}}. Final increases remaining: {{finalAttributeContext.finalRemaining}}.</p>
          <div class="sta2e-cc-score-adjust-list">
            {{#each finalAttributeContext.rows as |row|}}
            <div class="sta2e-cc-score-adjust-row {{#if row.correctedDown}}is-warning{{/if}}">
              <strong>{{row.label}}</strong>
              <span>{{row.value}}</span>
              <button type="button" data-final-score-step data-kind="attribute" data-mode="redistribution" data-score-key="{{row.key}}" data-delta="-1" {{#unless row.canRemoveRedistribution}}disabled{{/unless}} title="Remove redistribution"><i class="fas fa-minus"></i></button>
              <em>R {{row.redistribution}}</em>
              <button type="button" data-final-score-step data-kind="attribute" data-mode="redistribution" data-score-key="{{row.key}}" data-delta="1" {{#unless row.canAddRedistribution}}disabled{{/unless}} title="Add redistribution"><i class="fas fa-plus"></i></button>
              <button type="button" data-final-score-step data-kind="attribute" data-mode="final" data-score-key="{{row.key}}" data-delta="-1" {{#unless row.canRemoveFinal}}disabled{{/unless}} title="Remove final increase"><i class="fas fa-minus"></i></button>
              <em>F {{row.final}}</em>
              <button type="button" data-final-score-step data-kind="attribute" data-mode="final" data-score-key="{{row.key}}" data-delta="1" {{#unless row.canAddFinal}}disabled{{/unless}} title="Add final increase"><i class="fas fa-plus"></i></button>
            </div>
            {{/each}}
          </div>
        </article>

        <article class="sta2e-cc-panel">
          <h2>Department Check</h2>
          <p>{{#if untappedPotential}}Untapped Potential: departments cannot exceed 4.{{else}}Departments cannot exceed 5, and only one may be 5.{{/if}}</p>
          <p>Total: {{finalDepartmentTotal}} / 16</p>
          <p>Redistribution remaining: {{finalDepartmentContext.redistributionRemaining}}. Final increases remaining: {{finalDepartmentContext.finalRemaining}}.</p>
          <div class="sta2e-cc-score-adjust-list">
            {{#each finalDepartmentContext.rows as |row|}}
            <div class="sta2e-cc-score-adjust-row {{#if row.correctedDown}}is-warning{{/if}}">
              <strong>{{row.label}}</strong>
              <span>{{row.value}}</span>
              <button type="button" data-final-score-step data-kind="department" data-mode="redistribution" data-score-key="{{row.key}}" data-delta="-1" {{#unless row.canRemoveRedistribution}}disabled{{/unless}} title="Remove redistribution"><i class="fas fa-minus"></i></button>
              <em>R {{row.redistribution}}</em>
              <button type="button" data-final-score-step data-kind="department" data-mode="redistribution" data-score-key="{{row.key}}" data-delta="1" {{#unless row.canAddRedistribution}}disabled{{/unless}} title="Add redistribution"><i class="fas fa-plus"></i></button>
              <button type="button" data-final-score-step data-kind="department" data-mode="final" data-score-key="{{row.key}}" data-delta="-1" {{#unless row.canRemoveFinal}}disabled{{/unless}} title="Remove final increase"><i class="fas fa-minus"></i></button>
              <em>F {{row.final}}</em>
              <button type="button" data-final-score-step data-kind="department" data-mode="final" data-score-key="{{row.key}}" data-delta="1" {{#unless row.canAddFinal}}disabled{{/unless}} title="Add final increase"><i class="fas fa-plus"></i></button>
            </div>
            {{/each}}
          </div>
        </article>
      </section>
    </div>

    <div data-cc-creator-panel-group="finishing" data-cc-creator-panel="value" hidden>
      <section class="sta2e-cc-grid sta2e-cc-two">
        <article class="sta2e-cc-panel">
          <h2>Final Value</h2>
          <label class="sta2e-cc-field">
            <span>Configured Value</span>
            <div class="sta2e-cc-inline-actions">
              <select data-field="finalValue">
                <option value="">Choose value</option>
                {{#each finalValueOptions as |value|}}
                <option value="{{value.uuid}}" {{#if value.selected}}selected{{/if}}>{{value.name}}</option>
                {{/each}}
              </select>
              <button type="button" data-action="randomFinalValue" title="Roll random value">
                <i class="fas fa-dice"></i>
              </button>
            </div>
          </label>
          <input type="text" data-field="finalCustomValueName" value="{{finalCustomValueName}}" placeholder="Custom value" />
          <textarea data-field="finalCustomValueDescription" rows="2" placeholder="Custom value description">{{finalCustomValueDescription}}</textarea>
        </article>

        <article class="sta2e-cc-panel">
          <h2>Extra Talent</h2>
          <p>Chosen talents: {{selectedTalentCount}} / 3 before this extra talent.</p>
          <label class="sta2e-cc-toggle sta2e-cc-toggle--compact">
            <input type="checkbox" data-field="gmAllowEsotericTalents" {{checked gmAllowEsotericTalents}} />
            <span>GM Allow Esoteric Talents</span>
          </label>
          <details class="sta2e-cc-choice-collapse" data-talent-filter-root {{#unless selectedFinalTalent}}open{{/unless}}>
            <summary>{{#if selectedFinalTalent}}Selected: {{selectedFinalTalent.name}}{{else}}Choose Talent{{/if}}</summary>
          <label class="sta2e-cc-field sta2e-cc-talent-search">
            <span>Search Talents</span>
            <input type="search" data-talent-filter placeholder="Search talents" autocomplete="off" />
          </label>
          <ul class="sta2e-cc-choice-list" data-talent-filter-list>
            {{#each finalTalentChoices as |talent|}}
            <li class="{{#unless talent.available}}is-disabled{{/unless}}" data-description-root data-talent-option>
              <label class="sta2e-cc-talent-radio">
                <input type="radio" name="finalTalent" data-field="finalTalent" value="{{talent.uuid}}" {{#if talent.selected}}checked{{/if}} {{#unless talent.available}}disabled{{/unless}} />
                <strong>{{talent.name}}</strong>
              </label>
              {{#if talent.typeLabel}}<span>{{talent.typeLabel}}</span>{{/if}}
              {{#if talent.requirementLabel}}<span>{{talent.requirementLabel}}</span>{{/if}}
              {{#if talent.description}}
              <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
              <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{talent.description}}}</div>
              {{/if}}
            </li>
            {{/each}}
            <li class="is-empty" data-talent-filter-empty hidden>No talents match this search.</li>
            {{#unless finalTalentChoices.length}}
            <li class="is-empty">No eligible talents are available.</li>
            {{/unless}}
          </ul>
          </details>
        </article>
      </section>
    </div>

    <div data-cc-creator-panel-group="finishing" data-cc-creator-panel="details" hidden>
      <section class="sta2e-cc-grid sta2e-cc-two">
        <article class="sta2e-cc-panel">
          <h2>Role Selection</h2>
          <details class="sta2e-cc-choice-collapse" {{#unless selectedRole}}open{{/unless}}>
            <summary>{{#if selectedRole}}Selected: {{selectedRole.name}}{{else}}Choose Role{{/if}}</summary>
            <ul class="sta2e-cc-choice-list">
            {{#each roleOptions as |role|}}
              <li class="{{#if role.selected}}is-selected{{/if}}" data-description-root>
                <label class="sta2e-cc-talent-radio">
                  <input type="radio" name="role" data-field="role" value="{{role.uuid}}" {{#if role.selected}}checked{{/if}} />
                  <strong>{{role.name}}</strong>
                </label>
                {{#if role.type}}<span>{{role.type}}</span>{{/if}}
                {{#if role.description}}
                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{role.description}}}</div>
                {{/if}}
              </li>
            {{/each}}
              {{#unless roleOptions.length}}<li class="is-empty">No roles configured.</li>{{/unless}}
            </ul>
          </details>
        </article>

        <article class="sta2e-cc-panel">
          <h2>Rank Selection</h2>
          <details class="sta2e-cc-choice-collapse" {{#unless selectedRank}}open{{/unless}}>
            <summary>{{#if selectedRank}}Selected: {{selectedRank.name}}{{else}}Choose Rank{{/if}}</summary>
            <ul class="sta2e-cc-choice-list">
            {{#each rankOptions as |rank|}}
              <li class="{{#if rank.selected}}is-selected{{/if}}" data-description-root>
                <label class="sta2e-cc-talent-radio">
                  <input type="radio" name="rankSelect" data-field="rankSelect" value="{{rank.id}}" {{#if rank.selected}}checked{{/if}} />
                  <strong>{{rank.name}}</strong>
                </label>
                {{#if rank.description}}
                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{rank.description}}</div>
                {{/if}}
              </li>
            {{/each}}
              {{#unless rankOptions.length}}<li class="is-empty">No ranks configured.</li>{{/unless}}
            </ul>
          </details>
          <label class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Custom Rank</span>
            <input type="text" data-field="rank" value="{{customRank}}" placeholder="Custom rank" />
          </label>
        </article>

        <article class="sta2e-cc-panel">
          <h2>Service Details</h2>
          <div class="sta2e-cc-final-details-grid">
            {{#if canSelectPastime}}
            <label class="sta2e-cc-field">
              <span>Pastime</span>
              <input type="text" data-field="pastime" value="{{pastime}}" placeholder="Pastime" />
            </label>
            {{else}}
            <div class="sta2e-cc-text-panel">
              <h2>Pastime</h2>
              <p>Holograms do not select a pastime without Expanded Programming.</p>
            </div>
            {{/if}}
            <label class="sta2e-cc-field">
              <span>Assignment</span>
              <input type="text" data-field="assignment" value="{{assignment}}" placeholder="Assignment" />
            </label>
            <label class="sta2e-cc-field">
              <span>Pronouns</span>
              <input type="text" data-field="pronouns" value="{{pronouns}}" placeholder="Pronouns" />
            </label>
          </div>
          {{#if hasExpandedProgrammingTalent}}
          <div class="sta2e-cc-free-attrs">
            <h2>Expanded Programming Focuses</h2>
            <p>Select up to two additional focuses.</p>
            {{#each expandedProgrammingFocusSelections as |slot|}}
            <div class="sta2e-cc-field sta2e-cc-field--wide">
              <span>Expanded Focus {{slot.number}}</span>
              <select data-field="expandedProgrammingFocus" data-index="{{slot.index}}">
                <option value="">Choose configured focus</option>
                {{#each slot.options as |focus|}}
                <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
                {{/each}}
              </select>
              <input type="text" data-field="expandedProgrammingCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
            </div>
            {{/each}}
          </div>
          {{/if}}
        </article>

        <article class="sta2e-cc-panel">
          <h2>Equipment</h2>
          <details class="sta2e-cc-choice-collapse" open>
            <summary>Role{{#if selectedRole}}: {{selectedRole.name}}{{/if}}</summary>
            {{#unless selectedRole}}<p>Choose a role to see configured equipment.</p>{{/unless}}
            <ul class="sta2e-cc-choice-list">
              {{#each roleEquipment as |item|}}
              <li data-description-root>
                <strong>{{item.name}}</strong>
                {{#if item.type}}<span>{{item.type}}</span>{{/if}}
                {{#if item.description}}
                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
                {{/if}}
              </li>
              {{/each}}
              {{#unless roleEquipment.length}}<li class="is-empty">No equipment configured for this role.</li>{{/unless}}
            </ul>
          </details>
          <details class="sta2e-cc-choice-collapse" open>
            <summary>Rank{{#if selectedRank}}: {{selectedRank.name}}{{/if}}</summary>
            {{#unless selectedRank}}<p>Choose a configured rank to see rank equipment.</p>{{/unless}}
            <ul class="sta2e-cc-choice-list">
              {{#each rankEquipment as |item|}}
              <li data-description-root>
                <strong>{{item.name}}</strong>
                {{#if item.type}}<span>{{item.type}}</span>{{/if}}
                {{#if item.description}}
                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
                {{/if}}
              </li>
              {{/each}}
              {{#unless rankEquipment.length}}<li class="is-empty">No equipment configured for this rank.</li>{{/unless}}
            </ul>
          </details>
        </article>
      </section>
    </div>
    {{/if}}

    {{#if reviewActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Scores</h2>
        <p>Attributes {{finalAttributeTotal}} / 56. Departments {{finalDepartmentTotal}} / 16.</p>
        <div class="sta2e-cc-score-grid">
          {{#each finalAttributeContext.rows as |row|}}<div><span>{{row.label}}</span><strong>{{row.value}}</strong></div>{{/each}}
          {{#each finalDepartmentContext.rows as |row|}}<div><span>{{row.label}}</span><strong>{{row.value}}</strong></div>{{/each}}
        </div>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Details</h2>
        <dl class="sta2e-cc-summary">
          <dt>Name</dt><dd>{{#if characterName}}{{characterName}}{{else}}Unnamed character{{/if}}</dd>
          <dt>Role</dt><dd>{{#if selectedRole}}{{selectedRole.name}}{{else}}None selected{{/if}}</dd>
          <dt>Pastime</dt><dd>{{#if pastime}}{{pastime}}{{else}}None entered{{/if}}</dd>
          <dt>Rank</dt><dd>{{#if rank}}{{rank}}{{else}}None entered{{/if}}</dd>
          <dt>Assignment</dt><dd>{{#if assignment}}{{assignment}}{{else}}None entered{{/if}}</dd>
          <dt>Pronouns</dt><dd>{{#if pronouns}}{{pronouns}}{{else}}None entered{{/if}}</dd>
        </dl>
      </article>
    </section>

    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Traits, Values, and Focuses</h2>
        <ul class="sta2e-cc-choice-list">
          {{#each traitList as |trait|}}<li><strong>{{trait.name}}</strong></li>{{/each}}
          {{#if selectedHumanAugmentFlawTrait}}<li><strong>{{selectedHumanAugmentFlawTrait.name}}</strong></li>{{/if}}
          {{#if selectedCareerTrait}}<li><strong>{{selectedCareerTrait.name}}</strong></li>{{/if}}
          {{#each eventTraitSummary as |trait|}}<li><strong>{{trait.name}}</strong></li>{{/each}}
          {{#unless traitList.length}}{{#unless selectedHumanAugmentFlawTrait}}{{#unless selectedCareerTrait}}{{#unless eventTraitSummary.length}}<li class="is-empty">No traits selected.</li>{{/unless}}{{/unless}}{{/unless}}{{/unless}}
        </ul>
        <p>Focuses selected: {{focusCount}} / {{focusTargetCount}}.</p>
        <ul class="sta2e-cc-choice-list">
          {{#each valueSummary as |value|}}<li><strong>{{value.name}}</strong></li>{{/each}}
          {{#unless valueSummary.length}}<li class="is-empty">No values selected.</li>{{/unless}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each focusSummary as |focus|}}<li><strong>{{focus.name}}</strong></li>{{/each}}
          {{#unless focusSummary.length}}<li class="is-empty">No focuses selected.</li>{{/unless}}
        </ul>
      </article>
      <article class="sta2e-cc-panel">
        <h2>Talents and Equipment</h2>
        <ul class="sta2e-cc-choice-list">
          {{#each selectedTalentSummary as |talent|}}<li><strong>{{talent.name}}</strong></li>{{/each}}
          {{#unless selectedTalentSummary.length}}<li class="is-empty">No talents selected.</li>{{/unless}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each roleEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
          {{#unless roleEquipment.length}}<li class="is-empty">No role equipment configured.</li>{{/unless}}
        </ul>
        <ul class="sta2e-cc-choice-list">
          {{#each rankEquipment as |item|}}<li><strong>{{item.name}}</strong></li>{{/each}}
          {{#unless rankEquipment.length}}<li class="is-empty">No rank equipment configured.</li>{{/unless}}
        </ul>
      </article>
    </section>
    {{/if}}

    <footer class="sta2e-cc-footer">
      <button type="button" data-action="previousStep">Back</button>
      {{#if stepOneActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Environment</button>
      {{/if}}
      {{#if stepTwoActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Upbringing</button>
      {{/if}}
      {{#if stepThreeActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Career Path</button>
      {{/if}}
      {{#if stepFourActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Experience</button>
      {{/if}}
      {{#if stepFiveActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Career Events</button>
      {{/if}}
      {{#if stepSixActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Next: Finishing Touches</button>
      {{/if}}
      {{#if stepSevenActive}}
      <button type="button" class="sta2e-cc-primary" data-action="nextStep">Review</button>
      {{/if}}
      {{#if reviewActive}}
      <button type="button" class="sta2e-cc-primary" data-action="finalizeCharacter">
        <i class="fas fa-user-plus"></i> Finalize Character
      </button>
      {{/if}}
    </footer>
    {{else}}
    <section class="sta2e-cc-empty">
      <p>No species are configured yet.</p>
      <button type="button" data-action="openConfig">
        <i class="fas fa-gear"></i> Open Creator Data
      </button>
    </section>
    {{/if}}
    {{/if}}

    {{#if isNpcCharacter}}
    {{#if hasNpcSpeciesChoice}}
    <section class="sta2e-cc-panel">
      <div class="sta2e-cc-title-row">
        <div>
          <h2>NPC Preview</h2>
          <p>Personal Threat {{npcPersonalThreat}}. Attributes {{npcAttributeTotal}}. Departments {{npcDepartmentTotal}}.</p>
        </div>
        <button type="button" class="sta2e-cc-primary" data-action="randomizeNpc">
          <i class="fas fa-dice"></i> Randomize NPC
        </button>
      </div>
      <div class="sta2e-cc-score-grid">
        {{#each npcAttributeRows as |attr|}}
        <div class="{{#if attr.boosted}}is-boosted{{/if}}">
          <span>{{attr.label}}</span>
          <strong>{{attr.value}}</strong>
        </div>
        {{/each}}
        {{#each npcDepartmentRows as |disc|}}
        <div>
          <span>{{disc.label}}</span>
          <strong>{{disc.value}}</strong>
        </div>
        {{/each}}
      </div>
    </section>

    {{#if stepOneActive}}
    <section class="sta2e-cc-grid sta2e-cc-two sta2e-cc-species-grants-grid">
      <article class="sta2e-cc-panel sta2e-cc-species-list-panel">
        <div class="sta2e-cc-title-row">
          <h2>Species</h2>
          {{#unless isNpcCustomSpecies}}
          <label class="sta2e-cc-toggle">
            <input type="checkbox" data-field="mixedSpecies" {{checked mixedSpecies}} {{#if mixedSpeciesForced}}disabled{{/if}} />
            <span>Mixed Species</span>
          </label>
          {{/unless}}
          <label class="sta2e-cc-toggle">
            <input type="checkbox" data-field="npcUseCustomSpecies" {{checked isNpcCustomSpecies}} />
            <span>Custom Species</span>
          </label>
        </div>
        {{#if isNpcCustomSpecies}}
        <div class="sta2e-cc-final-details-grid">
          <label class="sta2e-cc-field">
            <span>Species Name</span>
            <input type="text" data-field="npcCustomSpeciesName" value="{{npcCustomSpeciesName}}" placeholder="Creature species" />
          </label>
          <label class="sta2e-cc-field">
            <span>Token Image</span>
            <input type="text" data-field="npcCustomSpeciesTokenImage" value="{{npcCustomSpeciesTokenImage}}" placeholder="icons/svg/mystery-man.svg" />
          </label>
          <label class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Description</span>
            <textarea data-field="npcCustomSpeciesDescription" rows="2" placeholder="Species description">{{npcCustomSpeciesDescription}}</textarea>
          </label>
          <label class="sta2e-cc-field">
            <span>Trait Name</span>
            <input type="text" data-field="npcCustomSpeciesTraitName" value="{{npcCustomSpeciesTraitName}}" placeholder="Species trait" />
          </label>
          <label class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Trait Description</span>
            <textarea data-field="npcCustomSpeciesTraitDescription" rows="2" placeholder="Trait description">{{npcCustomSpeciesTraitDescription}}</textarea>
          </label>
          <label class="sta2e-cc-field">
            <span>Ability Name</span>
            <input type="text" data-field="npcCustomSpeciesAbilityName" value="{{npcCustomSpeciesAbilityName}}" placeholder="Species ability" />
          </label>
          <label class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Ability Description</span>
            <textarea data-field="npcCustomSpeciesAbilityDescription" rows="2" placeholder="Ability description">{{npcCustomSpeciesAbilityDescription}}</textarea>
          </label>
          <label class="sta2e-cc-field">
            <span>Extra Focuses</span>
            <input type="number" data-field="npcCustomSpeciesExtraFocusCount" value="{{npcCustomSpeciesExtraFocusCount}}" min="0" max="6" />
          </label>
        </div>
        <div class="sta2e-cc-free-attrs">
          <h2>Fixed Attribute Boosts</h2>
          <div class="sta2e-cc-check-grid">
            {{#each npcCustomSpeciesAttributeBoostChoices as |attr|}}
            <label class="{{#if attr.disabled}}is-disabled{{/if}}">
              <input type="checkbox" data-field="npcCustomSpeciesAttributeBoost" value="{{attr.key}}" {{checked attr.selected}} {{#if attr.disabled}}disabled{{/if}} />
              {{attr.label}} +1
            </label>
            {{/each}}
          </div>
        </div>
        <div class="sta2e-cc-free-attrs">
          <h2>Attribute Choice Pool</h2>
          <div class="sta2e-cc-check-grid">
            {{#each npcCustomSpeciesAttributeChoiceBoostChoices as |attr|}}
            <label class="{{#if attr.disabled}}is-disabled{{/if}}">
              <input type="checkbox" data-field="npcCustomSpeciesAttributeChoiceBoost" value="{{attr.key}}" {{checked attr.selected}} {{#if attr.disabled}}disabled{{/if}} />
              {{attr.label}}
            </label>
            {{/each}}
          </div>
        </div>
        {{else}}
        <label class="sta2e-cc-field sta2e-cc-species-search">
          <span>Search Species</span>
          <input type="search" data-species-filter value="{{speciesSearch}}" placeholder="Filter species" />
        </label>
        <ul class="sta2e-cc-choice-list sta2e-cc-species-card-list">
          {{#each speciesOptions as |species|}}
          <li data-species-card data-species-name="{{species.name}}" class="{{#if species.primarySelected}}is-primary{{/if}} {{#if species.secondarySelected}}is-secondary{{/if}}">
            <div class="sta2e-cc-species-card-head">
              <div class="sta2e-cc-species-card-title">
                {{#if species.tokenImage}}<img src="{{species.tokenImage}}" alt="{{species.name}} token image" />{{/if}}
                <strong>{{species.name}}</strong>
              </div>
              <div class="sta2e-cc-card-chip-row">
                {{#if species.primarySelected}}<span class="sta2e-cc-chip">Primary</span>{{/if}}
                {{#if species.secondarySelected}}<span class="sta2e-cc-chip">Secondary</span>{{/if}}
              </div>
            </div>
            <div class="sta2e-cc-card-chip-row">
              {{#if species.freeAttributeSelection}}
              <span class="sta2e-cc-chip">Any 3 Attributes</span>
              {{else}}
              {{#each species.attributeLabels as |attr|}}<span class="sta2e-cc-chip">{{attr.label}} +1</span>{{/each}}
              {{#if species.attributeChoiceLabel}}<span class="sta2e-cc-chip">{{species.attributeChoiceLabel}} +1</span>{{/if}}
              {{/if}}
            </div>
            <div class="sta2e-cc-species-card-actions">
              <label class="sta2e-cc-talent-radio">
                <input type="radio" name="primarySpecies" data-field="primarySpecies" value="{{species.id}}" {{#if species.primarySelected}}checked{{/if}} />
                <span>Primary</span>
              </label>
              {{#if species.showSecondaryPicker}}
              <label class="sta2e-cc-talent-radio {{#if species.disabledAsSecondary}}is-disabled{{/if}}">
                <input type="radio" name="secondarySpecies" data-field="secondarySpecies" value="{{species.id}}" {{#if species.secondarySelected}}checked{{/if}} {{#if species.disabledAsSecondary}}disabled{{/if}} />
                <span>Secondary</span>
              </label>
              {{/if}}
            </div>
          </li>
          {{/each}}
          <li class="is-empty" data-species-filter-empty hidden>No species match this search.</li>
        </ul>
        {{/if}}
      </article>

      <article class="sta2e-cc-panel">
        <h2>Species Grants</h2>
        <dl class="sta2e-cc-summary">
          <dt>Trait</dt>
          <dd>
            {{#each traitList as |trait|}}<span class="sta2e-cc-chip">{{trait.name}}</span>{{/each}}
            {{#unless traitList.length}}No trait assigned{{/unless}}
          </dd>
          <dt>Species Ability</dt>
          <dd>{{#if primary.abilityName}}{{primary.abilityName}}{{else}}No ability assigned{{/if}}</dd>
        </dl>
        {{#if primaryFreeAttributeSelection}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Attribute Boosts</h2>
          <div class="sta2e-cc-check-grid">
            {{#each freeAttributeChoices as |attr|}}
            <label>
              <input type="checkbox" data-field="freeAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
              {{attr.label}}
            </label>
            {{/each}}
          </div>
        </div>
        {{/if}}
        {{#if hasSpeciesAttributeChoice}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Attribute Choice</h2>
          <div class="sta2e-cc-check-grid">
            {{#each speciesAttributeChoiceOptions as |attr|}}
            <label>
              <input type="radio" name="speciesAttributeChoice" data-field="speciesAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
              {{attr.label}} +1
            </label>
            {{/each}}
          </div>
        </div>
        {{/if}}
        {{#if speciesExtraFocusCount}}
        <div class="sta2e-cc-free-attrs">
          <h2>Species Bonus Focuses</h2>
          {{#each speciesFocusSelections as |slot|}}
          <div class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Species Focus {{slot.number}}</span>
            <select data-field="speciesFocus" data-index="{{slot.index}}">
              <option value="">Choose configured focus</option>
              {{#each slot.options as |focus|}}
              <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
              {{/each}}
            </select>
            <input type="text" data-field="speciesCustomFocusName" data-index="{{slot.index}}" value="{{slot.customName}}" placeholder="Custom focus" />
          </div>
          {{/each}}
        </div>
        {{/if}}
      </article>
    </section>
    {{/if}}

    {{#if stepTwoActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Attributes</h2>
        {{#if npcUsesPointBuy}}
        <p>{{npcAttributePointContext.remaining}} point(s) remaining.</p>
        <div class="sta2e-cc-attribute-steppers">
          {{#each npcAttributeRows as |row|}}
