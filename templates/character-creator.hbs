            <div class="sta2e-cc-inline-actions">
              <select data-field="careerEventFocus" data-index="{{slot.index}}">
                <option value="">Choose suggested focus</option>
                {{#each slot.focusOptions as |focus|}}
                <option value="{{focus.uuid}}" {{#if focus.selected}}selected{{/if}}>{{focus.name}}</option>
                {{/each}}
              </select>
              <button type="button" data-action="randomCareerEventFocus" data-index="{{slot.index}}" title="Roll random event focus">
                <i class="fas fa-dice"></i>
              </button>
            </div>
