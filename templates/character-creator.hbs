        <div class="sta2e-cc-attribute-steppers">
          {{#each npcDepartmentRows as |row|}}
          <div class="sta2e-cc-stepper">
            <span>{{row.label}}</span>
            <button type="button" data-npc-score-step data-kind="department" data-score-key="{{row.key}}" data-delta="-1" {{#unless row.canDecrease}}disabled{{/unless}} title="Decrease {{row.label}}">
              <i class="fas fa-minus"></i>
            </button>
            <input type="number" value="{{row.value}}" readonly />
            <button type="button" data-npc-score-step data-kind="department" data-score-key="{{row.key}}" data-delta="1" {{#unless row.canIncrease}}disabled{{/unless}} title="Increase {{row.label}}">
              <i class="fas fa-plus"></i>
            </button>
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="sta2e-cc-score-assign-list">
          {{#each npcDepartmentRows as |row|}}
          <div class="sta2e-cc-score-drop-row" data-supporting-score-drop data-score-kind="department" data-score-key="{{row.key}}">
            <span>{{row.label}}</span>
            <button type="button" class="sta2e-cc-score-chip" draggable="true" data-supporting-score-chip data-score-kind="department" data-score-key="{{row.key}}" data-score-value="{{row.value}}" title="Drag to swap values">
              {{row.value}}
            </button>
            <strong>{{row.value}}</strong>
          </div>
          {{/each}}
        </div>
        {{/if}}
      </article>
    </section>
    {{/if}}

    {{#if stepThreeActive}}
    <section class="sta2e-cc-grid sta2e-cc-two">
      <article class="sta2e-cc-panel">
        <h2>Core Details</h2>
        <div class="sta2e-cc-final-details-grid">
          <label class="sta2e-cc-field">
            <span>Rank</span>
            <select data-field="rankSelect">
              <option value="">Choose configured rank</option>
              {{#each rankOptions as |rank|}}
              <option value="{{rank.id}}" {{#if rank.selected}}selected{{/if}}>{{rank.name}}</option>
              {{/each}}
            </select>
          </label>
          <label class="sta2e-cc-field">
            <span>Custom Rank</span>
            <input type="text" data-field="rank" value="{{customRank}}" placeholder="Custom rank" />
          </label>
          <label class="sta2e-cc-field">
            <span>Assignment</span>
            <input type="text" data-field="assignment" value="{{assignment}}" placeholder="Guard Captain" />
          </label>
          <label class="sta2e-cc-field">
            <span>Pronouns</span>
            <input type="text" data-field="pronouns" value="{{pronouns}}" placeholder="Pronouns" />
          </label>
        </div>
      </article>

      <article class="sta2e-cc-panel">
        <h2>Role Trait</h2>
        <label class="sta2e-cc-field">
          <span>Configured Trait</span>
          <div class="sta2e-cc-inline-actions">
            <select data-field="npcRoleTrait">
              <option value="">Choose trait</option>
              {{#each npcTraitOptions as |trait|}}
              <option value="{{trait.uuid}}" {{#if trait.selected}}selected{{/if}}>{{trait.name}}</option>
              {{/each}}
            </select>
            <button type="button" class="sta2e-cc-icon-btn" data-action="randomNpcTrait" data-target="role" title="Roll random role trait">
              <i class="fas fa-dice"></i>
            </button>
          </div>
        </label>
        {{#if selectedNpcRoleTrait.description}}
        <div class="sta2e-cc-description-panel">{{{selectedNpcRoleTrait.description}}}</div>
        {{/if}}
        <input type="text" data-field="npcCustomRoleTraitName" value="{{npcCustomRoleTraitName}}" placeholder="Custom role trait" />
        <textarea data-field="npcCustomRoleTraitDescription" rows="2" placeholder="Custom role trait description">{{npcCustomRoleTraitDescription}}</textarea>
        {{#if npcDefinition.extraTraitCount}}
        <h2>Optional Extra Trait</h2>
        <label class="sta2e-cc-field">
          <span>Configured Trait</span>
          <div class="sta2e-cc-inline-actions">
            <select data-field="npcExtraTrait">
              <option value="">Choose trait</option>
              {{#each npcExtraTraitOptions as |trait|}}
              <option value="{{trait.uuid}}" {{#if trait.selected}}selected{{/if}}>{{trait.name}}</option>
              {{/each}}
            </select>
            <button type="button" class="sta2e-cc-icon-btn" data-action="randomNpcTrait" data-target="extra" title="Roll random extra trait">
              <i class="fas fa-dice"></i>
            </button>
          </div>
        </label>
        {{#if selectedNpcExtraTrait.description}}
        <div class="sta2e-cc-description-panel">{{{selectedNpcExtraTrait.description}}}</div>
        {{/if}}
        <input type="text" data-field="npcCustomExtraTraitName" value="{{npcCustomExtraTraitName}}" placeholder="Custom extra trait" />
        <textarea data-field="npcCustomExtraTraitDescription" rows="2" placeholder="Custom extra trait description">{{npcCustomExtraTraitDescription}}</textarea>
        {{/if}}
      </article>
    </section>

    {{#if npcValueLimit}}
    <section class="sta2e-cc-panel">
      <h2>Values</h2>
      <p>{{npcValueCount}} / {{npcValueLimit}} selected.</p>
      {{#each npcValueSelections as |slot|}}
      <div class="sta2e-cc-field sta2e-cc-field--wide">
        <span>Value {{slot.number}}</span>
        <div class="sta2e-cc-inline-actions">
          <select data-field="npcValue" data-index="{{slot.index}}">
            <option value="">Choose value</option>
            {{#each slot.options as |value|}}
            <option value="{{value.uuid}}" {{#if value.selected}}selected{{/if}} {{#if value.disabled}}disabled{{/if}}>{{value.name}}</option>
            {{/each}}
          </select>
          <button type="button" class="sta2e-cc-icon-btn" data-action="randomNpcValue" data-index="{{slot.index}}" title="Roll random value">
            <i class="fas fa-dice"></i>
          </button>
          {{#if slot.canEdit}}
          <button type="button" class="sta2e-cc-icon-btn" data-action="editNpcValue" data-index="{{slot.index}}" title="Edit name and description">
            <i class="fas fa-pen"></i>
          </button>
          {{/if}}
          {{#if slot.editing}}
          <button type="button" class="sta2e-cc-icon-btn" data-action="cancelEditNpcValue" data-index="{{slot.index}}" title="Revert to original">
            <i class="fas fa-undo"></i>
          </button>
          {{/if}}
          {{#if slot.removable}}
          <button type="button" class="sta2e-cc-icon-btn" data-action="removeNpcValue" data-index="{{slot.index}}" title="Remove this slot">
            <i class="fas fa-times"></i>
          </button>
          {{/if}}
