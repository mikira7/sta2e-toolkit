          {{#if slot.event.description}}
          <div class="sta2e-cc-text-panel">
            {{{slot.event.description}}}
          </div>
          {{/if}}

          <dl class="sta2e-cc-summary">
            <dt>Attribute</dt>
            <dd>
              {{#if slot.needsAttributeChoice}}
              <select data-field="careerEventAttribute" data-index="{{slot.index}}">
                <option value="">Choose attribute</option>
                {{#each slot.attributeChoices as |attr|}}
                <option value="{{attr.key}}" {{#if attr.selected}}selected{{/if}}>{{attr.label}}</option>
                {{/each}}
              </select>
              {{else}}
              <span class="sta2e-cc-chip">{{slot.attributeLabel}} +1</span>
              {{/if}}
            </dd>
            <dt>Department</dt>
            <dd>
              {{#if slot.needsDepartmentChoice}}
              <select data-field="careerEventDepartment" data-index="{{slot.index}}">
                <option value="">Choose department</option>
                {{#each slot.departmentChoices as |department|}}
                <option value="{{department.key}}" {{#if department.selected}}selected{{/if}}>{{department.label}}</option>
                {{/each}}
              </select>
              {{else}}
              <span class="sta2e-cc-chip">{{slot.departmentLabel}} +1</span>
              {{/if}}
            </dd>
          </dl>

