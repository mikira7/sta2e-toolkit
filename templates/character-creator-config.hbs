          <label class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Environment Description</span>
            <prose-mirror data-field="environmentDescription" name="environmentDescription_{{environment.id}}" value="{{environment.description}}"></prose-mirror>
          </label>

          <div class="sta2e-cc-grid">
            <label class="sta2e-cc-field">
              <span>Value Description</span>
              <prose-mirror data-field="environmentValueDescription" name="environmentValueDescription_{{environment.id}}" value="{{environment.valueDescription}}"></prose-mirror>
            </label>

            <div class="sta2e-cc-field">
              <span>Attribute Rule</span>
              <select data-field="environmentAttributeMode">
                {{#each environment.attributeModeOptions as |option|}}
                <option value="{{option.key}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                {{/each}}
              </select>
              <prose-mirror data-field="environmentAttributeDescription" name="environmentAttributeDescription_{{environment.id}}" value="{{environment.attributeDescription}}"></prose-mirror>
              <div class="sta2e-cc-check-grid">
                {{#each environment.attributes as |attr|}}
                <label>
                  <input type="checkbox" data-field="environmentAttributeChoice" value="{{attr.key}}" {{checked attr.selected}} />
