<div class="sta2e-cc-config">
  <nav class="sta2e-cc-config-tabs">
    <button type="button" class="is-active" data-cc-config-tab="config">Config</button>
    <button type="button" data-cc-config-tab="species">01 Species</button>
    <button type="button" data-cc-config-tab="environment">02 Environment</button>
    <button type="button" data-cc-config-tab="upbringing">03 Upbringing</button>
    <button type="button" data-cc-config-tab="career">04 Career Path</button>
    <button type="button" data-cc-config-tab="experience">05 Experience</button>
    <button type="button" data-cc-config-tab="events">06 Career Events</button>
    <button type="button" data-cc-config-tab="finishing">07 Finishing</button>
    <button type="button" data-cc-config-tab="supporting">Supporting / Supervisory</button>
  </nav>

  <section class="sta2e-cc-section" data-cc-config-panel="config">
    <div class="sta2e-cc-section-head">
      <div>
        <h2>Creator Config</h2>
        <p>Store the shared roles, talents, traits, values, focuses, items, weapons, and armor that later creation steps can draw from.</p>
      </div>
    </div>

    <label class="sta2e-cc-field">
      <div class="sta2e-cc-field-head">
        <span>Talent Source Packs</span>
        <div class="sta2e-cc-action-row">
          <button type="button" data-import-section="talentPacks" title="Import Talent Packs JSON">
            <i class="fas fa-file-import"></i> Import
          </button>
          <button type="button" data-export-section="talentPacks" title="Export Talent Packs JSON">
            <i class="fas fa-file-export"></i> Export
          </button>
          <input type="file" accept="application/json,.json" data-section-import-input="talentPacks" hidden />
        </div>
      </div>
      <textarea data-field="talentPacks" rows="3" placeholder="sta.items-2e&#10;world.custom-talents">{{talentPacksText}}</textarea>
    </label>

    <div class="sta2e-cc-config-block {{#if configCollapsed.talents}}is-collapsed{{/if}}" data-config-section="talents">
      <div class="sta2e-cc-config-block-head">
        <h3>Talents</h3>
        <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.talents}}false{{else}}true{{/if}}" title="{{#if configCollapsed.talents}}Expand section{{else}}Collapse section{{/if}}">
          <i class="fas {{#if configCollapsed.talents}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
        </button>
      </div>
      <div data-config-block-body {{#if configCollapsed.talents}}hidden{{/if}}>
        <nav class="sta2e-cc-subtabs">
          {{#each config.talentCategories as |category|}}
          <button type="button" class="{{#if category.active}}is-active{{/if}}" data-cc-subtab-group="talents" data-cc-subtab="{{category.key}}">{{category.label}}</button>
          {{/each}}
        </nav>

        {{#each config.talentCategories as |category|}}
        <section class="sta2e-cc-subpanel" data-cc-subtab-panel-group="talents" data-cc-subtab-panel="{{category.key}}" {{#unless category.active}}hidden{{/unless}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="talent:{{category.key}}" data-config-type="talent">
            <i class="fas fa-star"></i>
            <strong>Drop {{category.label}} talent items or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="talent:{{category.key}}">
            {{#each category.items as |item|}}
            <li class="sta2e-cc-pill" data-description-root>
              <span>{{item.name}}</span>
              {{#if item.type}}<em>{{item.type}}</em>{{/if}}
              <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
              {{#if item.description}}
              <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
              <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
              {{/if}}
              <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
            </li>
            {{/each}}
          </ul>
        </section>
        {{/each}}
      </div>
    </div>

    <div class="sta2e-cc-grid">
      <div class="sta2e-cc-config-block {{#if configCollapsed.roles}}is-collapsed{{/if}}" data-config-section="roles">
        <div class="sta2e-cc-config-block-head">
          <h3>Roles</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.roles}}false{{else}}true{{/if}}" title="{{#if configCollapsed.roles}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.roles}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.roles}}hidden{{/if}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="roles" data-config-type="role">
            <i class="fas fa-user-tie"></i>
            <strong>Drop role talent items or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="roles">
          {{#each config.roles as |item|}}
          <li class="sta2e-cc-pill" data-description-root>
            <span>{{item.name}}</span>
            {{#if item.type}}<em>{{item.type}}</em>{{/if}}
            <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
            {{#if item.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
            {{/if}}
            <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
          </ul>
        </div>
      </div>

      <div class="sta2e-cc-config-block {{#if configCollapsed.traits}}is-collapsed{{/if}}" data-config-section="traits">
        <div class="sta2e-cc-config-block-head">
          <h3>Traits</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.traits}}false{{else}}true{{/if}}" title="{{#if configCollapsed.traits}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.traits}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.traits}}hidden{{/if}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="traits" data-config-type="trait">
            <i class="fas fa-tag"></i>
            <strong>Drop trait items or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="traits">
          {{#each config.traits as |item|}}
          <li class="sta2e-cc-pill" data-description-root>
            <span>{{item.name}}</span>
            {{#if item.type}}<em>{{item.type}}</em>{{/if}}
            <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
            {{#if item.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
            {{/if}}
            <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
          </ul>
        </div>
      </div>

      <div class="sta2e-cc-config-block {{#if configCollapsed.values}}is-collapsed{{/if}}" data-config-section="values">
        <div class="sta2e-cc-config-block-head">
          <h3>Values</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.values}}false{{else}}true{{/if}}" title="{{#if configCollapsed.values}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.values}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.values}}hidden{{/if}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="values" data-config-type="value">
            <i class="fas fa-id-card"></i>
            <strong>Drop value items or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="values">
          {{#each config.values as |item|}}
          <li class="sta2e-cc-pill" data-description-root>
            <span>{{item.name}}</span>
            {{#if item.type}}<em>{{item.type}}</em>{{/if}}
            <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
            {{#if item.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
            {{/if}}
            <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
          </ul>
        </div>
      </div>

      <div class="sta2e-cc-config-block {{#if configCollapsed.focuses}}is-collapsed{{/if}}" data-config-section="focuses">
        <div class="sta2e-cc-config-block-head">
          <h3>Focuses</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.focuses}}false{{else}}true{{/if}}" title="{{#if configCollapsed.focuses}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.focuses}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.focuses}}hidden{{/if}}>
          <p>Department focus tabs feed Supporting and Supervisory choices and the configured focus selectors used by player-character lifepath options.</p>
          <nav class="sta2e-cc-subtabs">
            {{#each config.departmentFocuses as |department|}}
            <button type="button" class="{{#if department.active}}is-active{{/if}}" data-cc-subtab-group="departmentFocuses" data-cc-subtab="{{department.key}}">{{department.label}}</button>
            {{/each}}
          </nav>
          {{#each config.departmentFocuses as |department|}}
          <section class="sta2e-cc-subpanel" data-cc-subtab-panel-group="departmentFocuses" data-cc-subtab-panel="{{department.key}}" {{#unless department.active}}hidden{{/unless}}>
            <div class="sta2e-cc-drop-slot" data-config-drop="departmentFocuses:{{department.key}}" data-config-type="focus">
              <i class="fas fa-crosshairs"></i>
              <strong>Drop {{department.label}} focus items or a folder here</strong>
            </div>
            <ul class="sta2e-cc-pill-list" data-config-list="departmentFocuses:{{department.key}}">
              {{#each department.items as |item|}}
              <li class="sta2e-cc-pill" data-description-root>
                <span>{{item.name}}</span>
                {{#if item.type}}<em>{{item.type}}</em>{{/if}}
                <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
                {{#if item.description}}
                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
                {{/if}}
                <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
              </li>
              {{/each}}
            </ul>
          </section>
          {{/each}}
        </div>
      </div>
    </div>

    <div class="sta2e-cc-grid">
      <div class="sta2e-cc-config-block {{#if configCollapsed.items}}is-collapsed{{/if}}" data-config-section="items">
        <div class="sta2e-cc-config-block-head">
          <h3>Items</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.items}}false{{else}}true{{/if}}" title="{{#if configCollapsed.items}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.items}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.items}}hidden{{/if}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="items" data-config-type="item">
            <i class="fas fa-toolbox"></i>
            <strong>Drop general item entries or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="items">
          {{#each config.items as |item|}}
          <li class="sta2e-cc-pill" data-description-root>
            <span>{{item.name}}</span>
            {{#if item.type}}<em>{{item.type}}</em>{{/if}}
            <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
            {{#if item.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
            {{/if}}
            <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
          </ul>
        </div>
      </div>

      <div class="sta2e-cc-config-block {{#if configCollapsed.weapons}}is-collapsed{{/if}}" data-config-section="weapons">
        <div class="sta2e-cc-config-block-head">
          <h3>Weapons</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.weapons}}false{{else}}true{{/if}}" title="{{#if configCollapsed.weapons}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.weapons}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.weapons}}hidden{{/if}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="weapons" data-config-type="weapon">
            <i class="fas fa-bolt"></i>
            <strong>Drop character weapon items or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="weapons">
          {{#each config.weapons as |item|}}
          <li class="sta2e-cc-pill" data-description-root>
            <span>{{item.name}}</span>
            {{#if item.type}}<em>{{item.type}}</em>{{/if}}
            <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
            {{#if item.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
            {{/if}}
            <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
          </ul>
        </div>
      </div>

      <div class="sta2e-cc-config-block {{#if configCollapsed.armor}}is-collapsed{{/if}}" data-config-section="armor">
        <div class="sta2e-cc-config-block-head">
          <h3>Armor</h3>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.armor}}false{{else}}true{{/if}}" title="{{#if configCollapsed.armor}}Expand section{{else}}Collapse section{{/if}}">
            <i class="fas {{#if configCollapsed.armor}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
        </div>
        <div data-config-block-body {{#if configCollapsed.armor}}hidden{{/if}}>
          <div class="sta2e-cc-drop-slot" data-config-drop="armor" data-config-type="armor">
            <i class="fas fa-shield-alt"></i>
            <strong>Drop armor items or a folder here</strong>
          </div>
          <ul class="sta2e-cc-pill-list" data-config-list="armor">
          {{#each config.armor as |item|}}
          <li class="sta2e-cc-pill" data-description-root>
            <span>{{item.name}}</span>
            {{#if item.type}}<em>{{item.type}}</em>{{/if}}
            <input type="hidden" data-field="configItemUuid" value="{{item.uuid}}" />
            {{#if item.description}}
            <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
            <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
            {{/if}}
            <button type="button" data-remove-config-item title="Remove item"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="sta2e-cc-section" data-cc-config-panel="species" hidden>
    <div class="sta2e-cc-section-head">
      <div>
        <h2>Step One: Species</h2>
        <p>Configure species traits, fixed or free attribute boosts, species abilities, and species talent pools.</p>
      </div>
      <div class="sta2e-cc-action-row">
        <button type="button" data-toggle-all-species data-collapse-mode="{{#if allSpeciesCollapsed}}expand{{else}}collapse{{/if}}" title="{{#if allSpeciesCollapsed}}Expand all species{{else}}Collapse all species{{/if}}">
          <i class="fas {{#if allSpeciesCollapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          <span data-collapse-all-label>{{#if allSpeciesCollapsed}}Expand All{{else}}Collapse All{{/if}}</span>
        </button>
        <button type="button" data-sort-species-name>
          <i class="fas fa-sort-alpha-down"></i> Sort by Name
        </button>
        <button type="button" data-import-section="species" title="Import Species JSON">
          <i class="fas fa-file-import"></i> Import
        </button>
        <button type="button" data-export-section="species" title="Export Species JSON">
          <i class="fas fa-file-export"></i> Export
        </button>
        <input type="file" accept="application/json,.json" data-section-import-input="species" hidden />
        <button type="button" data-action="addSpecies">
          <i class="fas fa-plus"></i> Add Species
        </button>
      </div>
    </div>

    <div class="sta2e-cc-species-list" data-species-list>
      {{#each species as |entry|}}
      <article class="sta2e-cc-species-row {{#if entry.collapsed}}is-collapsed{{/if}}" data-species-id="{{entry.id}}">
        <header>
          <button type="button" class="sta2e-cc-icon-btn" data-toggle-species aria-expanded="{{#if entry.collapsed}}false{{else}}true{{/if}}" title="{{#if entry.collapsed}}Expand species{{else}}Minimize species{{/if}}">
            <i class="fas {{#if entry.collapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
          </button>
          <input type="text" data-field="name" value="{{entry.name}}" placeholder="Species name" />
          <button type="button" data-action="deleteSpecies" data-species-id="{{entry.id}}" title="Delete species">
            <i class="fas fa-trash"></i>
          </button>
        </header>

        <div class="sta2e-cc-species-body" data-species-body {{#if entry.collapsed}}hidden{{/if}}>
          <div class="sta2e-cc-grid">
            <label class="sta2e-cc-field">
              <span>Species Token Image</span>
              <div class="sta2e-cc-inline-actions">
                <input type="text" data-field="tokenImage" value="{{entry.tokenImage}}" placeholder="icons/svg/mystery-man.svg or assets/species/vulcan.webp" />
                <button type="button" data-browse-species-token title="Browse token image">
                  <i class="fas fa-folder-open"></i>
                </button>
              </div>
            </label>
            <div class="sta2e-cc-species-token-config-preview" {{#unless entry.tokenImage}}hidden{{/unless}}>
              <img src="{{entry.tokenImage}}" alt="{{entry.name}} token image" data-species-token-preview />
            </div>
          </div>

          <label class="sta2e-cc-field sta2e-cc-field--wide">
            <span>Species Description</span>
            <prose-mirror data-field="description" name="speciesDescription_{{entry.id}}" value="{{entry.description}}"></prose-mirror>
          </label>

          <section class="sta2e-cc-config-block sta2e-cc-species-names-block">
            <div class="sta2e-cc-config-block-head">
              <h3>Names</h3>
              <div class="sta2e-cc-action-row">
                <button type="button" data-import-species-names title="Import species names">
                  <i class="fas fa-file-import"></i> Import
                </button>
                <button type="button" data-export-species-names title="Export species names">
                  <i class="fas fa-file-export"></i> Export
                </button>
                <button type="button" data-clear-species-names title="Clear species names">
                  <i class="fas fa-eraser"></i> Clear Names
                </button>
                <input type="file" accept="application/json,.json" data-species-names-import hidden />
              </div>
            </div>
            <label class="sta2e-cc-toggle sta2e-cc-toggle--compact">
              <input type="checkbox" data-field="surnameFirst" {{checked entry.surnameFirst}} />
              <span>Display surname first</span>
            </label>
            <div class="sta2e-cc-grid">
              <label class="sta2e-cc-field">
                <span>Male First Names</span>
                <textarea data-field="maleFirstNames" rows="5" placeholder="One male first name per line">{{entry.maleFirstNamesText}}</textarea>
              </label>
              <label class="sta2e-cc-field">
                <span>Female First Names</span>
                <textarea data-field="femaleFirstNames" rows="5" placeholder="One female first name per line">{{entry.femaleFirstNamesText}}</textarea>
              </label>
              <label class="sta2e-cc-field">
                <span>Surnames</span>
                <textarea data-field="surnames" rows="5" placeholder="One surname per line">{{entry.surnamesText}}</textarea>
              </label>
            </div>
          </section>

          <div class="sta2e-cc-grid">
            <div class="sta2e-cc-field">
              <span>Trait Items</span>
              <div class="sta2e-cc-drop-slot" data-drop-role="speciesTrait">
                <i class="fas fa-tag"></i>
                <strong>Drop trait items here</strong>
              </div>
              <ul class="sta2e-cc-pill-list" data-species-traits>
                {{#each entry.traits as |trait|}}
                <li class="sta2e-cc-pill" data-description-root>
                  <span>{{trait.name}}</span>
                  {{#if trait.type}}<em>{{trait.type}}</em>{{/if}}
                  <input type="hidden" data-field="speciesTraitUuid" value="{{trait.uuid}}" />
                  {{#if trait.description}}
                  <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                  <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{trait.description}}}</div>
                  {{/if}}
                  <button type="button" data-remove-upbringing-item title="Remove trait"><i class="fas fa-times"></i></button>
                </li>
                {{/each}}
              </ul>
            </div>

            <div class="sta2e-cc-field">
              <span>Attribute Rule</span>
              <label class="sta2e-cc-toggle sta2e-cc-toggle--compact">
                <input type="checkbox" data-field="freeAttributeSelection" {{checked entry.freeAttributeSelection}} />
                <span>Player chooses any three attributes</span>
              </label>
              <div class="sta2e-cc-check-grid">
                {{#each entry.attributes as |attr|}}
                <label>
                  <input type="checkbox" data-field="attributeBoost" value="{{attr.key}}" {{checked attr.selected}} />
                  {{attr.label}}
                </label>
                {{/each}}
              </div>
              <span>Choose-One Attribute Options</span>
              <div class="sta2e-cc-check-grid">
                {{#each entry.attributeChoices as |attr|}}
                <label>
                  <input type="checkbox" data-field="attributeChoiceBoost" value="{{attr.key}}" {{checked attr.selected}} />
                  {{attr.label}}
                </label>
                {{/each}}
              </div>
            </div>
          </div>

          <div class="sta2e-cc-grid">
            <div class="sta2e-cc-field">
              <span>Species Ability</span>
              <div class="sta2e-cc-drop-slot" data-drop-role="speciesAbility" data-description-root>
                <i class="fas fa-hand-sparkles"></i>
