                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
                {{/if}}
                <button type="button" data-remove-upbringing-item title="Remove equipment"><i class="fas fa-times"></i></button>
              </li>
              {{/each}}
            </ul>
          </div>
        </article>
        {{/each}}

        {{#unless roleLoadouts.length}}
        <div class="sta2e-cc-empty">
          Add roles to the Config tab before setting up role equipment.
        </div>
        {{/unless}}
      </div>
    </article>
  </section>

  <section class="sta2e-cc-section" data-cc-config-panel="supporting" hidden>
    <div class="sta2e-cc-section-head">
      <div>
        <h2>Supporting / Supervisory Config</h2>
        <p>Configure equipment granted to Supporting and Supervisory characters by selected department.</p>
      </div>
      <div class="sta2e-cc-action-row">
        <button type="button" data-import-section="supportingDepartments" title="Import Supporting Department Equipment JSON">
          <i class="fas fa-file-import"></i> Import
        </button>
        <button type="button" data-export-section="supportingDepartments" title="Export Supporting Department Equipment JSON">
          <i class="fas fa-file-export"></i> Export
        </button>
        <input type="file" accept="application/json,.json" data-section-import-input="supportingDepartments" hidden />
      </div>
    </div>

    <article class="sta2e-cc-panel sta2e-cc-config-block {{#if configCollapsed.supportingDepartments}}is-collapsed{{/if}}" data-config-section="supportingDepartments">
      <div class="sta2e-cc-config-block-head">
        <div>
          <h3>Department Equipment</h3>
          <p>These loadouts are granted from the required Supporting/Supervisory department choice.</p>
        </div>
        <button type="button" class="sta2e-cc-icon-btn" data-toggle-config-block aria-expanded="{{#if configCollapsed.supportingDepartments}}false{{else}}true{{/if}}" title="{{#if configCollapsed.supportingDepartments}}Expand section{{else}}Collapse section{{/if}}">
          <i class="fas {{#if configCollapsed.supportingDepartments}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
        </button>
      </div>

      <div class="sta2e-cc-species-list" data-config-block-body {{#if configCollapsed.supportingDepartments}}hidden{{/if}}>
        {{#each departmentLoadouts as |department|}}
        <article class="sta2e-cc-species-row sta2e-cc-department-loadout-row" data-department="{{department.key}}">
          <header>
            <button type="button" class="sta2e-cc-icon-btn" data-toggle-finishing-entry aria-expanded="true" title="Collapse department equipment">
              <i class="fas fa-chevron-up"></i>
            </button>
            <strong>{{department.label}}</strong>
          </header>
          <div class="sta2e-cc-species-body" data-finishing-entry-body>
            <div class="sta2e-cc-drop-slot" data-finishing-drop="departmentEquipment">
              <i class="fas fa-toolbox"></i>
              <strong>Drop {{department.label}} equipment, weapons, armor, or a folder here</strong>
            </div>
            <ul class="sta2e-cc-pill-list" data-department-loadout-list>
              {{#each department.equipment as |item|}}
              <li class="sta2e-cc-pill" data-description-root>
                <span>{{item.name}}</span>
                {{#if item.type}}<em>{{item.type}}</em>{{/if}}
                <input type="hidden" data-field="departmentLoadoutEquipmentUuid" value="{{item.uuid}}" />
                {{#if item.description}}
                <button type="button" class="sta2e-cc-link-btn" data-toggle-description>Description</button>
                <div class="sta2e-cc-description-panel" data-description-panel hidden>{{{item.description}}}</div>
                {{/if}}
                <button type="button" data-remove-upbringing-item title="Remove equipment"><i class="fas fa-times"></i></button>
              </li>
              {{/each}}
            </ul>
          </div>
        </article>
        {{/each}}
      </div>
    </article>
  </section>

  <div class="sta2e-cc-pack-actions">
    <span class="sta2e-cc-pack-actions-hint">Compendium pack import/export — bundles a full pack so creator references survive moving between worlds.</span>
    <button type="button" data-import-pack title="Import a previously-exported compendium pack JSON into a world-level pack">
      <i class="fas fa-file-import"></i> Import Pack
    </button>
    <button type="button" data-export-pack title="Export a compendium pack referenced by creator data as portable JSON">
      <i class="fas fa-file-export"></i> Export Pack
    </button>
    <input type="file" accept="application/json,.json" data-pack-import-input hidden />
  </div>

  <footer class="sta2e-cc-footer">
    <button type="button" data-action="cancel">Cancel</button>
    <button type="button" class="sta2e-cc-primary" data-action="save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>
</div>
