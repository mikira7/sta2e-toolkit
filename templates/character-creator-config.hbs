                  <input type="checkbox" data-field="environmentDepartmentChoice" value="{{department.key}}" {{checked department.selected}} />
                  {{department.label}}
                </label>
                {{/each}}
              </div>
            </div>
          </div>
        </div>
      </article>
      {{/each}}

      {{#unless environments.length}}
